@*
    Ligne label/valeur avec séparateur fin entre lignes successives.
    Utilisé dans les fiches détail (CoffeeDetail, ShopDetail, MachineDetail si on en faisait un).
*@
<div class="detail-row">
    <span class="detail-label">@Label</span>
    <span class="detail-value">@Value</span>
</div>

<style>
    .detail-row {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 12px;
        padding: 6px 0;
    }
    .detail-row + .detail-row {
        border-top: 1px solid var(--coffee-border);
    }
    .detail-label {
        color: var(--coffee-text-dim);
        font-size: 14px;
    }
    .detail-value {
        color: var(--coffee-text);
        font-weight: 500;
        text-align: right;
    }
</style>

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string Value { get; set; } = string.Empty;
}
