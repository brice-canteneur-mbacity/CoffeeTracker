@*
    Wrapper du MudRating de MudBlazor avec la palette ambre (étoiles non sélectionnées en
    coffee-300 #d4b487, sélectionnées en orange #f59e0b). Mode lecture seule via ReadOnly
    pour les listes / cartes ; ValueChanged pour les formulaires.
*@

<MudRating SelectedValue="Value"
           SelectedValueChanged="OnChanged"
           ReadOnly="ReadOnly"
           Size="@Size"
           MaxValue="5"
           FullIcon="@Icons.Material.Filled.Star"
           EmptyIcon="@Icons.Material.Filled.StarBorder"
           Class="coffee-rating" />

<style>
    .coffee-rating .mud-rating-item .mud-icon-root {
        color: #d4b487 !important;
    }
    .coffee-rating .mud-rating-item.mud-selected .mud-icon-root {
        color: #f59e0b !important;
    }
</style>

@code {
    [Parameter] public int Value { get; set; }
    [Parameter] public EventCallback<int> ValueChanged { get; set; }
    [Parameter] public bool ReadOnly { get; set; }
    [Parameter] public Size Size { get; set; } = Size.Medium;

    private async Task OnChanged(int v)
    {
        Value = v;
        if (ValueChanged.HasDelegate) await ValueChanged.InvokeAsync(v);
    }
}
