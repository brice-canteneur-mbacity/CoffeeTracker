@inherits LayoutComponentBase
@inject AlertsService Alerts
@inject MigrationService Migrations
@inject ISnackbar Snackbar

<MudLayout>
    <MudMainContent Class="pt-2">
        <div class="page-container">
            @Body
            <div class="bottom-nav-spacer"></div>
        </div>
    </MudMainContent>
    <BottomNav />
</MudLayout>

@code {
    private static bool _alertsEvaluated;

    protected override async Task OnInitializedAsync()
    {
        // Évaluation des alertes une seule fois par session.
        if (_alertsEvaluated) return;
        _alertsEvaluated = true;

        // Migrations data idempotentes (visites legacy → entités Shop, etc.).
        // S'exécute avant les alertes pour que celles-ci voient les bonnes données.
        try
        {
            var report = await Migrations.RunIfNeededAsync();
            if (report.HasChanges)
            {
                Snackbar.Add(
                    $"Migration : {report.ShopsCreated} shop(s) créé(s) depuis tes anciennes visites.",
                    Severity.Info);
            }
        }
        catch
        {
            // Échec migration ne doit pas bloquer le rendu — l'utilisateur retentera au reload.
        }

        try
        {
            var list = await Alerts.EvaluateAsync();
            if (list.Count == 0) return;

            var systemEnabled = await Alerts.IsEnabledAsync()
                && (await Alerts.GetPermissionAsync()) == "granted";

            foreach (var a in list)
            {
                var severity = a.Severity switch
                {
                    AlertSeverity.Error => Severity.Error,
                    AlertSeverity.Warning => Severity.Warning,
                    _ => Severity.Info
                };
                Snackbar.Add($"{a.Title} — {a.Message}", severity, opt => opt.RequireInteraction = false);

                if (systemEnabled) await Alerts.ShowSystemAsync(a);
            }
        }
        catch
        {
            // L'évaluation des alertes ne doit jamais bloquer le rendu de la page.
        }
    }
}
