@*
    Barre de navigation fixe en bas (style mobile) avec 5 onglets : Cafés / Brews / Machines /
    Shops / Stats. La détection « actif » écoute LocationChanged pour rerendre quand la route
    change sans réinstancier le composant.
*@
@implements IDisposable
@inject NavigationManager Nav

<nav class="bottom-nav">
    @foreach (var item in _items)
    {
        var active = IsActive(item.Path);
        <button type="button"
                class="@(active ? "bottom-nav-item active" : "bottom-nav-item")"
                @onclick="() => Nav.NavigateTo(item.Path)">
            <MudIcon Icon="@item.Icon" Size="Size.Medium" />
            <span>@item.Label</span>
        </button>
    }
</nav>

<style>
    .bottom-nav {
        position: fixed;
        inset: auto 0 0 0;
        background: var(--bottom-nav-bg);
        backdrop-filter: saturate(180%) blur(10px);
        border-top: 1px solid var(--coffee-border);
        padding-bottom: env(safe-area-inset-bottom);
        z-index: 1100;
        display: flex;
        max-width: 480px;
        margin: 0 auto;
    }
    .bottom-nav-item {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 2px;
        padding: 10px 4px;
        background: none;
        border: none;
        color: var(--coffee-text-dim);
        font-size: 11px;
        font-weight: 500;
        cursor: pointer;
        transition: color .15s ease;
    }
    .bottom-nav-item.active {
        color: var(--coffee-accent);
    }
    body.theme-dark .bottom-nav-item.active {
        color: var(--coffee-text);
    }
    .bottom-nav-item.active .mud-icon-root {
        transform: scale(1.05);
    }
    .bottom-nav-item:active {
        transform: scale(.96);
    }
</style>

@code {
    private record NavItem(string Path, string Label, string Icon);

    private readonly NavItem[] _items =
    {
        new("coffees", "Cafés", Icons.Material.Filled.Coffee),
        new("brews", "Brews", Icons.Material.Filled.LocalCafe),
        new("machines", "Machines", Icons.Material.Filled.CoffeeMaker),
        new("shops", "Shops", Icons.Material.Filled.Storefront),
        new("stats", "Stats", Icons.Material.Filled.BarChart)
    };

    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
    }

    private bool IsActive(string path)
    {
        // ToBaseRelativePath returns the path AFTER the base href, e.g. "coffees/5/edit" or "" at root.
        var current = Nav.ToBaseRelativePath(Nav.Uri).TrimEnd('/');
        if (path == "coffees" && current.Length == 0) return true;
        return current.StartsWith(path, StringComparison.OrdinalIgnoreCase);
    }
}
