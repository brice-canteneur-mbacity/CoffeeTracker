@page "/shops/{ShopId:int}/visits/new"
@page "/visits/{Id:int}/edit"
@inject CoffeeDb Db
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IDialogService Dialogs
@inject IJSRuntime JS
@inject SyncService Sync

<PageTitle>@(IsEdit ? "Modifier la visite" : "Nouvelle visite")</PageTitle>

<PageHeader Title="@(IsEdit ? "Modifier la visite" : "Nouvelle visite")"
            Subtitle="@(_shop?.Name ?? string.Empty)"
            Back="true" BackUrl="@BackTarget" />

@if (_loadingShop)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-4" />
}
else if (_shop is null)
{
    <MudPaper Class="pa-4" Elevation="0">
        <MudText>Shop introuvable. <MudLink Href="shops">Retour à la liste</MudLink>.</MudText>
    </MudPaper>
}
else
{
<EditForm Model="_model" OnValidSubmit="SaveAsync">
    <DataAnnotationsValidator />

    <MudStack Spacing="4">

        <MudPaper Class="pa-3" Elevation="0" Style="display:flex; align-items:center; gap:10px;">
            <MudIcon Icon="@Icons.Material.Filled.Storefront" Style="color: var(--coffee-accent-soft)" />
            <div style="flex:1; min-width:0;">
                <MudText Style="font-weight:600;" Class="text-truncate">@_shop.Name</MudText>
                @if (!string.IsNullOrEmpty(_shop.City) || !string.IsNullOrEmpty(_shop.Country))
                {
                    <MudText Typo="Typo.caption" Class="mud-text-secondary text-truncate">
                        @(string.Join(", ", new[] { _shop.City, _shop.Country }.Where(s => !string.IsNullOrEmpty(s))))
                    </MudText>
                }
            </div>
            <MudIconButton Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small"
                           OnClick="@(() => Nav.NavigateTo($"shops/{_shop.Id}"))"
                           aria-label="Ouvrir le shop" />
        </MudPaper>

        <MudPaper Class="pa-4" Elevation="0">
            <MudText Typo="Typo.overline" Class="mud-text-secondary mb-2">Photo</MudText>
            <div class="d-flex align-center" style="gap:12px;">
                @if (!string.IsNullOrEmpty(_model.PhotoDataUrl))
                {
                    <img src="@_model.PhotoDataUrl" class="photo-preview" alt="" />
                }
                else
                {
                    <div class="photo-preview placeholder">
                        <MudIcon Icon="@Icons.Material.Filled.PhotoCamera" />
                    </div>
                }
                <MudStack Spacing="1">
                    <InputFile id="visitPhotoInput" OnChange="OnPhotoSelectedAsync" accept="image/*" capture="environment" style="display:none;" />
                    <label for="visitPhotoInput" class="upload-button">
                        <MudIcon Icon="@Icons.Material.Filled.PhotoCamera" Size="Size.Small" />
                        <span>@(string.IsNullOrEmpty(_model.PhotoDataUrl) ? "Ajouter" : "Changer")</span>
                    </label>
                    @if (!string.IsNullOrEmpty(_model.PhotoDataUrl))
                    {
                        <MudButton Variant="Variant.Text" Color="Color.Default" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Close"
                                   OnClick="@(() => _model.PhotoDataUrl = null)">Retirer</MudButton>
                    }
                </MudStack>
            </div>
        </MudPaper>

        <MudPaper Class="pa-4" Elevation="0">
            <MudDatePicker @bind-Date="_date" Label="Date" Variant="Variant.Outlined" Editable="true" />
            <MudAutocomplete T="string"
                             Value="_model.DrinkType"
                             ValueChanged="@(v => _model.DrinkType = v)"
                             Label="Boisson *"
                             Placeholder="Espresso, V60, Cappuccino…"
                             Variant="Variant.Outlined"
                             Required="true"
                             SearchFunc="@SearchDrinksAsync"
                             CoerceText="true"
                             CoerceValue="true"
                             OpenOnFocus="true"
                             MinCharacters="0"
                             Clearable="true"
                             ResetValueOnEmptyText="false"
                             Class="mt-3" />
            <MudAutocomplete T="string"
                             Value="_model.CoffeeOrigin"
                             ValueChanged="@(v => _model.CoffeeOrigin = v)"
                             Label="Café"
                             Placeholder="ex : Éthiopie Sidamo, Geisha…"
                             Variant="Variant.Outlined"
                             SearchFunc="@SearchCoffeesAsync"
                             CoerceText="true"
                             CoerceValue="true"
                             OpenOnFocus="true"
                             MinCharacters="0"
                             Clearable="true"
                             ResetValueOnEmptyText="false"
                             Class="mt-3">
                <ItemTemplate Context="item">
                    <MudText>@item</MudText>
                </ItemTemplate>
                <NoItemsTemplate>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary pa-2">Aucun match — tape pour saisir un nouveau café.</MudText>
                </NoItemsTemplate>
            </MudAutocomplete>
            <MudGrid Spacing="2" Class="mt-1">
                <MudItem xs="8"><MudNumericField T="decimal?" @bind-Value="_model.Price" Label="Prix" Variant="Variant.Outlined" Format="0.##" Culture="@_inv" Min="0m" /></MudItem>
                <MudItem xs="4"><MudTextField @bind-Value="_model.Currency" Label="Devise" Variant="Variant.Outlined" /></MudItem>
            </MudGrid>
        </MudPaper>

        <MudPaper Class="pa-4" Elevation="0">
            <MudText Typo="Typo.overline" Class="mud-text-secondary mb-2">Score</MudText>
            <StarRating Value="@_model.Rating" ValueChanged="@((int v) => _model.Rating = v)" Size="Size.Large" />
        </MudPaper>

        <MudPaper Class="pa-4" Elevation="0">
            <MudTextField @bind-Value="_model.Notes" Label="Notes" Variant="Variant.Outlined" Lines="4" Placeholder="ex : extraction propre, ambiance top" />
        </MudPaper>

        <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Size="Size.Large"
                   StartIcon="@Icons.Material.Filled.Save" Disabled="_saving">
            @(IsEdit ? "Enregistrer" : "Créer la visite")
        </MudButton>

        @if (IsEdit)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Error" FullWidth="true"
                       StartIcon="@Icons.Material.Filled.Delete" OnClick="DeleteAsync">Supprimer</MudButton>
        }

    </MudStack>
</EditForm>
}

<style>
    .photo-preview { width: 80px; height: 80px; border-radius: 12px; object-fit: cover; }
    .photo-preview.placeholder { background: var(--coffee-surface-soft); display: flex; align-items: center; justify-content: center; color: var(--coffee-accent-soft); }
</style>

@code {
    [Parameter] public int? Id { get; set; }
    [Parameter] public int? ShopId { get; set; }
    private bool IsEdit => Id is not null;

    private CoffeeShopVisit _model = new();
    private Shop? _shop;
    private bool _loadingShop = true;
    private DateTime? _date = DateTime.Today;
    private bool _saving;
    private readonly System.Globalization.CultureInfo _inv = System.Globalization.CultureInfo.InvariantCulture;
    private List<Coffee> _allCoffees = new();
    private List<string> _knownCoffees = new();
    private List<string> _knownDrinks = new();

    private string BackTarget => _shop is not null ? $"shops/{_shop.Id}" : "shops";

    protected override async Task OnInitializedAsync()
    {
        // Préparation des suggestions d'autocomplete (toutes visites confondues).
        var visits = await Db.ShopVisits.ToCollection().ToList();
        _allCoffees = await Db.Coffees.ToCollection().ToList();
        _knownDrinks = Distinct(visits.Select(v => v.DrinkType));

        var libraryNames = _allCoffees.Select(c => c.Name);
        var legacyNames = visits.Select(v => v.CoffeeOrigin);
        _knownCoffees = Distinct(libraryNames.Concat(legacyNames));
    }

    protected override async Task OnParametersSetAsync()
    {
        _loadingShop = true;
        if (IsEdit)
        {
            var v = await Db.ShopVisits.Get(Id!.Value);
            if (v is not null)
            {
                _model = v;
                _date = v.Date.ToDateTime(TimeOnly.MinValue);
                _shop = v.ShopId > 0 ? await Db.Shops.Get(v.ShopId) : null;
                if (_model.CoffeeId is int cid)
                {
                    var c = _allCoffees.FirstOrDefault(x => x.Id == cid);
                    if (c is not null) _model.CoffeeOrigin = c.Name;
                }
            }
        }
        else if (ShopId is int sid)
        {
            _model.ShopId = sid;
            _shop = await Db.Shops.Get(sid);
        }
        _loadingShop = false;
    }

    private static List<string> Distinct(IEnumerable<string?> values)
        => values
            .Select(s => s?.Trim())
            .Where(s => !string.IsNullOrWhiteSpace(s))
            .Select(s => s!)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(s => s, StringComparer.OrdinalIgnoreCase)
            .ToList();

    private Task<IEnumerable<string>> SearchCoffeesAsync(string query, CancellationToken ct)
        => Filter(_knownCoffees, query);

    private Task<IEnumerable<string>> SearchDrinksAsync(string query, CancellationToken ct)
        => Filter(_knownDrinks, query);

    private static Task<IEnumerable<string>> Filter(List<string> source, string query)
    {
        IEnumerable<string> results = string.IsNullOrWhiteSpace(query)
            ? source
            : source.Where(s => s.Contains(query, StringComparison.OrdinalIgnoreCase));
        return Task.FromResult(results);
    }

    private async Task OnPhotoSelectedAsync(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;
        try
        {
            var maxBytes = 10 * 1024 * 1024;
            await using var stream = file.OpenReadStream(maxBytes);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            var bytes = ms.ToArray();
            var dataUrl = await JS.InvokeAsync<string>("coffeeImage.bytesToCompressedDataUrl",
                bytes, file.ContentType, 1024, 0.82);
            _model.PhotoDataUrl = dataUrl;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erreur image : {ex.Message}", Severity.Error);
        }
    }

    private async Task SaveAsync()
    {
        if (_shop is null) return;
        _saving = true;
        try
        {
            _model.Date = DateOnly.FromDateTime(_date ?? DateTime.Today);
            _model.ShopId = _shop.Id;
            await ResolveCoffeeReferenceAsync();

            if (IsEdit)
            {
                _model.Id = Id!.Value;
                await Db.ShopVisits.Put(_model);
                Snackbar.Add("Visite enregistrée", Severity.Success);
            }
            else
            {
                _model.CreatedAt = DateTime.UtcNow;
                _model.Id = 0;
                await Db.ShopVisits.Add(_model);
                Snackbar.Add("Visite créée", Severity.Success);
            }
            Sync.RequestPush();
            Nav.NavigateTo($"shops/{_shop.Id}");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erreur : {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    /// <summary>
    /// Résout le champ texte « Café » (_model.CoffeeOrigin) en FK Coffee :
    /// - Vide → CoffeeId=null, CoffeeOrigin=null
    /// - Match exact (case-insensible) avec un Coffee existant → CoffeeId, CoffeeOrigin=null
    /// - Pas de match → auto-crée un Coffee « Dégusté » et lie via CoffeeId
    /// </summary>
    private async Task ResolveCoffeeReferenceAsync()
    {
        var typed = _model.CoffeeOrigin?.Trim();
        if (string.IsNullOrEmpty(typed))
        {
            _model.CoffeeId = null;
            _model.CoffeeOrigin = null;
            return;
        }

        var match = _allCoffees.FirstOrDefault(c =>
            string.Equals(c.Name?.Trim(), typed, StringComparison.OrdinalIgnoreCase));
        if (match is not null)
        {
            _model.CoffeeId = match.Id;
            _model.CoffeeOrigin = null;
            return;
        }

        var newCoffee = new Coffee
        {
            Name = typed,
            Roaster = string.Empty,
            IsOwned = false,
            Process = Process.Washed,
            PurchaseDate = DateOnly.FromDateTime(DateTime.Today),
            CreatedAt = DateTime.UtcNow,
            UpdatedAt = DateTime.UtcNow
        };
        var newId = await Db.Coffees.Add(newCoffee);
        newCoffee.Id = newId;
        _allCoffees.Add(newCoffee);
        _model.CoffeeId = newId;
        _model.CoffeeOrigin = null;
        Snackbar.Add($"« {typed} » créé dans tes cafés dégustés", Severity.Info);
    }

    private async Task DeleteAsync()
    {
        var ok = await Dialogs.ShowMessageBoxAsync(new MessageBoxOptions
        {
            Title = "Supprimer ?",
            Message = "Supprimer cette visite ?",
            YesText = "Supprimer",
            CancelText = "Annuler"
        });
        if (ok != true || Id is null) return;
        await Db.ShopVisits.Delete(Id.Value);
        Sync.RequestPush();
        Snackbar.Add("Visite supprimée", Severity.Info);
        Nav.NavigateTo(_shop is not null ? $"shops/{_shop.Id}" : "shops");
    }
}
