@*
    CRUD machine. Suppression « soft » : les brews qui référencent la machine gardent l'ID
    en orphelin (ils n'apparaîtront plus avec le nom mais ne seront pas supprimés).
*@
@page "/machines/new"
@page "/machines/{Id:int}/edit"
@implements IDisposable
@inject CoffeeDb Db
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IDialogService Dialogs
@inject IJSRuntime JS
@inject SyncService Sync
@inject LocalizationService Loc

<PageTitle>@(IsEdit ? Loc.T("machineform.title_edit") : Loc.T("machineform.title_new"))</PageTitle>

<PageHeader Title="@(IsEdit ? Loc.T("machineform.title_edit") : Loc.T("machineform.title_new"))" Back="true" BackUrl="machines" />

<EditForm Model="_model" OnValidSubmit="SaveAsync">
    <DataAnnotationsValidator />

    <MudStack Spacing="4">

        <MudPaper Class="pa-4" Elevation="0">
            <MudText Typo="Typo.overline" Class="mud-text-secondary mb-2">@Loc.T("coffeeform.section_photo")</MudText>
            <div class="d-flex align-center" style="gap:12px;">
                @if (!string.IsNullOrEmpty(_model.PhotoDataUrl))
                {
                    <img src="@_model.PhotoDataUrl" class="photo-preview" alt="" />
                }
                else
                {
                    <div class="photo-preview placeholder">
                        <MudIcon Icon="@Icons.Material.Filled.PhotoCamera" />
                    </div>
                }
                <MudStack Spacing="1">
                    <InputFile id="machinePhotoInput" OnChange="OnPhotoSelectedAsync" accept="image/*" capture="environment" style="display:none;" />
                    <label for="machinePhotoInput" class="upload-button">
                        <MudIcon Icon="@Icons.Material.Filled.PhotoCamera" Size="Size.Small" />
                        <span>@(string.IsNullOrEmpty(_model.PhotoDataUrl) ? Loc.T("coffeeform.photo_add") : Loc.T("coffeeform.photo_change"))</span>
                    </label>
                    @if (!string.IsNullOrEmpty(_model.PhotoDataUrl))
                    {
                        <MudButton Variant="Variant.Text" Color="Color.Default" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Close"
                                   OnClick="@(() => _model.PhotoDataUrl = null)">@Loc.T("coffeeform.photo_remove")</MudButton>
                    }
                </MudStack>
            </div>
        </MudPaper>

        <MudPaper Class="pa-4" Elevation="0">
            <MudTextField @bind-Value="_model.Name" Label="@Loc.T("machineform.field_name")" Variant="Variant.Outlined" Required="true" Placeholder="@Loc.T("machineform.field_name_placeholder")" Class="mb-3" />
            <MudSelect T="MachineType" @bind-Value="_model.Type" Label="@Loc.T("machineform.field_type")" Variant="Variant.Outlined" Class="mb-3">
                @foreach (var t in MachineTypeOrder.DisplayOrder)
                {
                    <MudSelectItem T="MachineType" Value="@t">@t.GetLabel()</MudSelectItem>
                }
            </MudSelect>
            <MudGrid Spacing="2">
                <MudItem xs="6"><MudTextField @bind-Value="_model.Brand" Label="@Loc.T("machineform.field_brand")" Variant="Variant.Outlined" /></MudItem>
                <MudItem xs="6"><MudTextField @bind-Value="_model.Model" Label="@Loc.T("machineform.field_model")" Variant="Variant.Outlined" /></MudItem>
            </MudGrid>
        </MudPaper>

        <MudPaper Class="pa-4" Elevation="0">
            <MudText Typo="Typo.overline" Class="mud-text-secondary mb-2">@Loc.T("machineform.section_purchase")</MudText>
            <MudGrid Spacing="2">
                <MudItem xs="12">
                    <MudDatePicker @bind-Date="_purchaseDate" Label="@Loc.T("machineform.field_purchase_date")" Variant="Variant.Outlined" Editable="true" Clearable="true" />
                </MudItem>
                <MudItem xs="8">
                    <MudNumericField T="decimal?" @bind-Value="_model.Price" Label="@Loc.T("coffeeform.field_price")" Variant="Variant.Outlined" Format="0.##" Culture="@_inv" Min="0m" />
                </MudItem>
                <MudItem xs="4">
                    <MudTextField @bind-Value="_model.Currency" Label="@Loc.T("coffeeform.field_currency")" Variant="Variant.Outlined" />
                </MudItem>
            </MudGrid>
        </MudPaper>

        <MudPaper Class="pa-4" Elevation="0">
            <MudTextField @bind-Value="_model.Notes" Label="@Loc.T("coffeeform.field_tasting_notes")" Variant="Variant.Outlined" Lines="4" Placeholder="@Loc.T("machineform.field_notes_placeholder")" />
        </MudPaper>

        <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Size="Size.Large"
                   StartIcon="@Icons.Material.Filled.Save" Disabled="_saving">
            @(IsEdit ? Loc.T("common.save") : Loc.T("machineform.btn_create"))
        </MudButton>

        @if (IsEdit)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Error" FullWidth="true"
                       StartIcon="@Icons.Material.Filled.Delete" OnClick="DeleteAsync">@Loc.T("common.delete")</MudButton>
        }

    </MudStack>
</EditForm>

<style>
    .photo-preview { width: 80px; height: 80px; border-radius: 12px; object-fit: cover; }
    .photo-preview.placeholder { background: var(--coffee-surface-soft); display: flex; align-items: center; justify-content: center; color: var(--coffee-accent-soft); }
</style>

@code {
    [Parameter] public int? Id { get; set; }
    private bool IsEdit => Id is not null;

    private Machine _model = new();
    private DateTime? _purchaseDate;
    private bool _saving;
    /// <summary>Culture de saisie utilisateur (FR/EN/IT) — pour que la virgule décimale soit bien parsée.</summary>
    private System.Globalization.CultureInfo _inv => System.Globalization.CultureInfo.CurrentCulture;

    protected override void OnInitialized() => Loc.LanguageChanged += OnLangChanged;
    private void OnLangChanged() => InvokeAsync(StateHasChanged);
    public void Dispose() => Loc.LanguageChanged -= OnLangChanged;

    protected override async Task OnParametersSetAsync()
    {
        if (IsEdit)
        {
            var m = await Db.Machines.Get(Id!.Value);
            if (m is not null)
            {
                _model = m;
                _purchaseDate = m.PurchaseDate?.ToDateTime(TimeOnly.MinValue);
            }
        }
    }

    private async Task OnPhotoSelectedAsync(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;
        try
        {
            var maxBytes = 10 * 1024 * 1024;
            await using var stream = file.OpenReadStream(maxBytes);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            var bytes = ms.ToArray();
            var dataUrl = await JS.InvokeAsync<string>("coffeeImage.bytesToCompressedDataUrl",
                bytes, file.ContentType, 1024, 0.82);
            _model.PhotoDataUrl = dataUrl;
        }
        catch (Exception ex)
        {
            Snackbar.Add(Loc.T("coffeeform.photo_error", ex.Message), Severity.Error);
        }
    }

    private async Task SaveAsync()
    {
        _saving = true;
        try
        {
            _model.PurchaseDate = _purchaseDate is null ? null : DateOnly.FromDateTime(_purchaseDate.Value);
            _model.UpdatedAt = DateTime.UtcNow;

            if (IsEdit)
            {
                _model.Id = Id!.Value;
                await Db.Machines.Put(_model);
                Snackbar.Add(Loc.T("machineform.snack_saved"), Severity.Success);
            }
            else
            {
                _model.CreatedAt = DateTime.UtcNow;
                _model.Id = 0;
                await Db.Machines.Add(_model);
                Snackbar.Add(Loc.T("machineform.snack_created"), Severity.Success);
            }
            Sync.RequestPush();
            Nav.NavigateTo("machines");
        }
        catch (Exception ex)
        {
            Snackbar.Add(Loc.T("common.error_prefix", ex.Message), Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task DeleteAsync()
    {
        var ok = await Dialogs.ShowMessageBoxAsync(new MessageBoxOptions
        {
            Title = Loc.T("coffeeform.btn_delete_confirm_title"),
            Message = Loc.T("machineform.btn_delete_confirm_msg"),
            YesText = Loc.T("common.delete"),
            CancelText = Loc.T("common.cancel")
        });
        if (ok != true || Id is null) return;
        await Db.Machines.Delete(Id.Value);
        Sync.RequestPush();
        Snackbar.Add(Loc.T("machineform.snack_deleted"), Severity.Info);
        Nav.NavigateTo("machines");
    }
}
