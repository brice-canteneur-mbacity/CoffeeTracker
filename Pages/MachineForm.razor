@page "/machines/new"
@page "/machines/{Id:int}/edit"
@inject CoffeeDb Db
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IDialogService Dialogs
@inject IJSRuntime JS

<PageTitle>@(IsEdit ? "Modifier la machine" : "Nouvelle machine")</PageTitle>

<PageHeader Title="@(IsEdit ? "Modifier la machine" : "Nouvelle machine")" Back="true" BackUrl="/machines" />

<EditForm Model="_model" OnValidSubmit="SaveAsync">
    <DataAnnotationsValidator />

    <MudStack Spacing="4">

        <MudPaper Class="pa-4" Elevation="0">
            <MudText Typo="Typo.overline" Class="mud-text-secondary mb-2">Photo</MudText>
            <div class="d-flex align-center" style="gap:12px;">
                @if (!string.IsNullOrEmpty(_model.PhotoDataUrl))
                {
                    <img src="@_model.PhotoDataUrl" class="photo-preview" alt="" />
                }
                else
                {
                    <div class="photo-preview placeholder">
                        <MudIcon Icon="@Icons.Material.Filled.PhotoCamera" />
                    </div>
                }
                <MudStack Spacing="1">
                    <InputFile id="machinePhotoInput" OnChange="OnPhotoSelectedAsync" accept="image/*" capture="environment" style="display:none;" />
                    <label for="machinePhotoInput" class="upload-button">
                        <MudIcon Icon="@Icons.Material.Filled.PhotoCamera" Size="Size.Small" />
                        <span>@(string.IsNullOrEmpty(_model.PhotoDataUrl) ? "Ajouter" : "Changer")</span>
                    </label>
                    @if (!string.IsNullOrEmpty(_model.PhotoDataUrl))
                    {
                        <MudButton Variant="Variant.Text" Color="Color.Default" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Close"
                                   OnClick="@(() => _model.PhotoDataUrl = null)">Retirer</MudButton>
                    }
                </MudStack>
            </div>
        </MudPaper>

        <MudPaper Class="pa-4" Elevation="0">
            <MudTextField @bind-Value="_model.Name" Label="Nom *" Variant="Variant.Outlined" Required="true" Placeholder="ex : Profitec Pro 600" Class="mb-3" />
            <MudSelect T="MachineType" @bind-Value="_model.Type" Label="Type" Variant="Variant.Outlined" Class="mb-3">
                @foreach (var t in MachineTypeOrder.DisplayOrder)
                {
                    <MudSelectItem T="MachineType" Value="@t">@t.GetLabel()</MudSelectItem>
                }
            </MudSelect>
            <MudGrid Spacing="2">
                <MudItem xs="6"><MudTextField @bind-Value="_model.Brand" Label="Marque" Variant="Variant.Outlined" /></MudItem>
                <MudItem xs="6"><MudTextField @bind-Value="_model.Model" Label="Modèle" Variant="Variant.Outlined" /></MudItem>
            </MudGrid>
        </MudPaper>

        <MudPaper Class="pa-4" Elevation="0">
            <MudText Typo="Typo.overline" Class="mud-text-secondary mb-2">Achat (optionnel)</MudText>
            <MudGrid Spacing="2">
                <MudItem xs="12">
                    <MudDatePicker @bind-Date="_purchaseDate" Label="Date d'achat" Variant="Variant.Outlined" Editable="true" Clearable="true" />
                </MudItem>
                <MudItem xs="8">
                    <MudNumericField T="decimal?" @bind-Value="_model.Price" Label="Prix" Variant="Variant.Outlined" Format="0.##" Culture="@_inv" Min="0m" />
                </MudItem>
                <MudItem xs="4">
                    <MudTextField @bind-Value="_model.Currency" Label="Devise" Variant="Variant.Outlined" />
                </MudItem>
            </MudGrid>
        </MudPaper>

        <MudPaper Class="pa-4" Elevation="0">
            <MudTextField @bind-Value="_model.Notes" Label="Notes" Variant="Variant.Outlined" Lines="4" Placeholder="ex : réglages, dernière révision…" />
        </MudPaper>

        <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Size="Size.Large"
                   StartIcon="@Icons.Material.Filled.Save" Disabled="_saving">
            @(IsEdit ? "Enregistrer" : "Créer la machine")
        </MudButton>

        @if (IsEdit)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Error" FullWidth="true"
                       StartIcon="@Icons.Material.Filled.Delete" OnClick="DeleteAsync">Supprimer</MudButton>
        }

    </MudStack>
</EditForm>

<style>
    .photo-preview { width: 80px; height: 80px; border-radius: 12px; object-fit: cover; }
    .photo-preview.placeholder { background: #f6efe4; display: flex; align-items: center; justify-content: center; color: #a06d3b; }
</style>

@code {
    [Parameter] public int? Id { get; set; }
    private bool IsEdit => Id is not null;

    private Machine _model = new();
    private DateTime? _purchaseDate;
    private bool _saving;
    private readonly System.Globalization.CultureInfo _inv = System.Globalization.CultureInfo.InvariantCulture;

    protected override async Task OnParametersSetAsync()
    {
        if (IsEdit)
        {
            var m = await Db.Machines.Get(Id!.Value);
            if (m is not null)
            {
                _model = m;
                _purchaseDate = m.PurchaseDate?.ToDateTime(TimeOnly.MinValue);
            }
        }
    }

    private async Task OnPhotoSelectedAsync(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;
        try
        {
            var maxBytes = 10 * 1024 * 1024;
            await using var stream = file.OpenReadStream(maxBytes);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            var bytes = ms.ToArray();
            var dataUrl = await JS.InvokeAsync<string>("coffeeImage.bytesToCompressedDataUrl",
                bytes, file.ContentType, 1024, 0.82);
            _model.PhotoDataUrl = dataUrl;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erreur image : {ex.Message}", Severity.Error);
        }
    }

    private async Task SaveAsync()
    {
        _saving = true;
        try
        {
            _model.PurchaseDate = _purchaseDate is null ? null : DateOnly.FromDateTime(_purchaseDate.Value);
            _model.UpdatedAt = DateTime.UtcNow;

            if (IsEdit)
            {
                _model.Id = Id!.Value;
                await Db.Machines.Put(_model);
                Snackbar.Add("Machine enregistrée", Severity.Success);
            }
            else
            {
                _model.CreatedAt = DateTime.UtcNow;
                _model.Id = 0;
                await Db.Machines.Add(_model);
                Snackbar.Add("Machine créée", Severity.Success);
            }
            Nav.NavigateTo("/machines");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erreur : {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task DeleteAsync()
    {
        var ok = await Dialogs.ShowMessageBoxAsync(new MessageBoxOptions
        {
            Title = "Supprimer ?",
            Message = "Supprimer cette machine ? Les brews qui la référencent garderont la référence (orpheline).",
            YesText = "Supprimer",
            CancelText = "Annuler"
        });
        if (ok != true || Id is null) return;
        await Db.Machines.Delete(Id.Value);
        Snackbar.Add("Machine supprimée", Severity.Info);
        Nav.NavigateTo("/machines");
    }
}
