@*
    CRUD Shop (lieu). N'édite PAS les visites — pour ça voir VisitForm.razor.
    En mode création : bouton « Rechercher en ligne » → PlaceSearchDialog (Google ou OSM)
    qui pré-remplit nom/ville/pays/adresse/lat/long/ExternalPlaceId.
    Après création, redirige vers /shops/{newId} (le détail) — l'utilisateur ajoute les visites de là.
*@
@page "/shops/new"
@page "/shops/{Id:int}/edit"
@implements IDisposable
@inject CoffeeDb Db
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IDialogService Dialogs
@inject IJSRuntime JS
@inject PlaceSearchService PlaceSearch
@inject SyncService Sync
@inject LocalizationService Loc

<PageTitle>@(IsEdit ? Loc.T("shopform.title_edit") : Loc.T("shopform.title_new"))</PageTitle>

<PageHeader Title="@(IsEdit ? Loc.T("shopform.title_edit") : Loc.T("shopform.title_new"))" Back="true" BackUrl="@BackTarget" />

<EditForm Model="_model" OnValidSubmit="SaveAsync">
    <DataAnnotationsValidator />

    <MudStack Spacing="4">

        <MudPaper Class="pa-4" Elevation="0">
            <MudText Typo="Typo.overline" Class="mud-text-secondary mb-2">@Loc.T("coffeeform.section_photo")</MudText>
            <div class="d-flex align-center" style="gap:12px;">
                @if (!string.IsNullOrEmpty(_model.PhotoDataUrl))
                {
                    <img src="@_model.PhotoDataUrl" class="photo-preview" alt="" />
                }
                else
                {
                    <div class="photo-preview placeholder">
                        <MudIcon Icon="@Icons.Material.Filled.PhotoCamera" />
                    </div>
                }
                <MudStack Spacing="1">
                    <InputFile id="shopPhotoInput" OnChange="OnPhotoSelectedAsync" accept="image/*" capture="environment" style="display:none;" />
                    <label for="shopPhotoInput" class="upload-button">
                        <MudIcon Icon="@Icons.Material.Filled.PhotoCamera" Size="Size.Small" />
                        <span>@(string.IsNullOrEmpty(_model.PhotoDataUrl) ? Loc.T("coffeeform.photo_add") : Loc.T("coffeeform.photo_change"))</span>
                    </label>
                    @if (!string.IsNullOrEmpty(_model.PhotoDataUrl))
                    {
                        <MudButton Variant="Variant.Text" Color="Color.Default" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Close"
                                   OnClick="@(() => _model.PhotoDataUrl = null)">@Loc.T("coffeeform.photo_remove")</MudButton>
                    }
                </MudStack>
            </div>
        </MudPaper>

        <MudPaper Class="pa-4" Elevation="0">
            @if (!IsEdit)
            {
                <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.TravelExplore"
                           FullWidth="true" Class="mb-3"
                           OnClick="OpenSearchAsync">
                    @Loc.T("shopform.search_online")
                </MudButton>
            }
            <MudTextField @bind-Value="_model.Name" Label="@Loc.T("shopform.field_name")"
                          Variant="Variant.Outlined" Required="true"
                          Placeholder="@Loc.T("shopform.field_name_placeholder")" Class="mb-3" />
            <MudGrid Spacing="2">
                <MudItem xs="6"><MudTextField @bind-Value="_model.City" Label="@Loc.T("shopform.field_city")" Variant="Variant.Outlined" Placeholder="@Loc.T("shopform.field_city_placeholder")" /></MudItem>
                <MudItem xs="6"><MudTextField @bind-Value="_model.Country" Label="@Loc.T("shopform.field_country")" Variant="Variant.Outlined" Placeholder="@Loc.T("shopform.field_country_placeholder")" /></MudItem>
                <MudItem xs="12"><MudTextField @bind-Value="_model.Address" Label="@Loc.T("shopform.field_address")" Variant="Variant.Outlined" Placeholder="@Loc.T("shopform.field_address_placeholder")" /></MudItem>
            </MudGrid>
            @if (_model.Latitude is not null && _model.Longitude is not null)
            {
                <MudText Typo="Typo.caption" Class="mud-text-secondary mt-2 d-block">
                    <MudIcon Icon="@Icons.Material.Filled.Place" Size="Size.Small" />
                    @_model.Latitude.Value.ToString("0.#####", _inv), @_model.Longitude.Value.ToString("0.#####", _inv)
                    @if (!string.IsNullOrEmpty(_model.ExternalPlaceId))
                    {
                        <span class="ml-2">· @Loc.T("shopform.gps_source", ProviderLabel(_model.ExternalPlaceId))</span>
                    }
                </MudText>
            }
        </MudPaper>

        <MudPaper Class="pa-4" Elevation="0">
            <MudTextField @bind-Value="_model.Notes" Label="@Loc.T("shopform.field_notes")" Variant="Variant.Outlined" Lines="4"
                          Placeholder="@Loc.T("shopform.field_notes_placeholder")" />
        </MudPaper>

        <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Size="Size.Large"
                   StartIcon="@Icons.Material.Filled.Save" Disabled="_saving">
            @(IsEdit ? Loc.T("common.save") : Loc.T("shopform.btn_create"))
        </MudButton>

    </MudStack>
</EditForm>

<style>
    .photo-preview { width: 80px; height: 80px; border-radius: 12px; object-fit: cover; }
    .photo-preview.placeholder { background: var(--coffee-surface-soft); display: flex; align-items: center; justify-content: center; color: var(--coffee-accent-soft); }
</style>

@code {
    [Parameter] public int? Id { get; set; }
    private bool IsEdit => Id is not null;

    private Shop _model = new();
    private bool _saving;
    private readonly System.Globalization.CultureInfo _inv = System.Globalization.CultureInfo.InvariantCulture;

    private string BackTarget => IsEdit ? $"shops/{Id}" : "shops";

    protected override void OnInitialized() => Loc.LanguageChanged += OnLangChanged;
    private void OnLangChanged() => InvokeAsync(StateHasChanged);
    public void Dispose() => Loc.LanguageChanged -= OnLangChanged;

    protected override async Task OnParametersSetAsync()
    {
        if (IsEdit)
        {
            var s = await Db.Shops.Get(Id!.Value);
            if (s is not null) _model = s;
        }
    }

    private async Task OpenSearchAsync()
    {
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true };
        var dialogRef = await Dialogs.ShowAsync<PlaceSearchDialog>(Loc.T("placesearch.title"), options);
        var result = await dialogRef.Result;
        if (result is null || result.Canceled) return;
        if (result.Data is not PlaceResult place) return;

        _model.Name = place.Name;
        if (!string.IsNullOrEmpty(place.Address)) _model.Address = place.Address;
        if (!string.IsNullOrEmpty(place.City)) _model.City = place.City;
        if (!string.IsNullOrEmpty(place.Country)) _model.Country = place.Country;
        _model.Latitude = place.Latitude;
        _model.Longitude = place.Longitude;
        _model.ExternalPlaceId = place.ExternalId;
        Snackbar.Add(Loc.T("shopform.snack_imported", place.Name, ProviderLabel(place.ExternalId)), Severity.Success);
        StateHasChanged();
    }

    private string ProviderLabel(string? externalId)
    {
        if (string.IsNullOrEmpty(externalId)) return Loc.T("common.none");
        if (externalId.StartsWith("google:", StringComparison.Ordinal)) return Loc.T("placesearch.provider_google");
        if (externalId.StartsWith("osm:", StringComparison.Ordinal)) return Loc.T("placesearch.provider_osm");
        return externalId;
    }

    private async Task OnPhotoSelectedAsync(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;
        try
        {
            var maxBytes = 10 * 1024 * 1024;
            await using var stream = file.OpenReadStream(maxBytes);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            var bytes = ms.ToArray();
            var dataUrl = await JS.InvokeAsync<string>("coffeeImage.bytesToCompressedDataUrl",
                bytes, file.ContentType, 1024, 0.82);
            _model.PhotoDataUrl = dataUrl;
        }
        catch (Exception ex)
        {
            Snackbar.Add(Loc.T("coffeeform.photo_error", ex.Message), Severity.Error);
        }
    }

    private async Task SaveAsync()
    {
        _saving = true;
        try
        {
            _model.UpdatedAt = DateTime.UtcNow;
            if (IsEdit)
            {
                _model.Id = Id!.Value;
                await Db.Shops.Put(_model);
                Sync.RequestPush();
                Snackbar.Add(Loc.T("shopform.snack_saved"), Severity.Success);
                Nav.NavigateTo($"shops/{Id}");
            }
            else
            {
                _model.CreatedAt = DateTime.UtcNow;
                _model.Id = 0;
                var newId = await Db.Shops.Add(_model);
                Sync.RequestPush();
                Snackbar.Add(Loc.T("shopform.snack_created"), Severity.Success);
                Nav.NavigateTo($"shops/{newId}");
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(Loc.T("common.error_prefix", ex.Message), Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }
}
