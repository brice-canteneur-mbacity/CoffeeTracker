@*
    CRUD brew. Trois modes d'arrivée :
    - /brews/new                    → nouveau brew vide (ou pré-rempli avec ?coffeeId=X)
    - /brews/new?fromBrewId=X       → duplication : copie la recette de X, date/heure = NOW
    - /brews/{Id}/edit              → édition d'un brew existant
    Tout l'init param-dépendant est dans OnParametersSetAsync (et pas OnInitializedAsync) car Blazor
    réutilise l'instance entre les routes /brews/{Id}/edit et /brews/new (même @page racine).
    Le yield est auto-calculé à partir de Dose × Ratio cible. Les machines proposées sont
    filtrées selon la méthode du brew (cf. MachineTypeOrder.BrewerTypeFor).
*@
@page "/brews/new"
@page "/brews/{Id:int}/edit"
@implements IDisposable
@inject CoffeeDb Db
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IDialogService Dialogs
@inject SyncService Sync
@inject LocalizationService Loc

<PageTitle>@(IsEdit ? Loc.T("brewform.title_edit") : Loc.T("brewform.title_new"))</PageTitle>

<PageHeader Title="@(IsEdit ? Loc.T("brewform.title_edit") : Loc.T("brewform.title_new"))" Back="true" BackUrl="brews" />

<EditForm Model="_model" OnValidSubmit="SaveAsync">
    <DataAnnotationsValidator />

    <MudStack Spacing="4">

        <MudPaper Class="pa-4" Elevation="0">
            <MudSelect T="int" @bind-Value="_model.CoffeeId" Label="@Loc.T("brewform.field_coffee")" Variant="Variant.Outlined" Required="true" RequiredError="@Loc.T("brewform.field_coffee_required")">
                @foreach (var c in _coffees)
                {
                    <MudSelectItem T="int" Value="@c.Id">@c.Roaster · @c.Name@(c.FinishedAt is null ? "" : $" {Loc.T("brewform.field_coffee_finished")}")</MudSelectItem>
                }
            </MudSelect>
            @if (_coffees.Count == 0)
            {
                <MudText Typo="Typo.caption" Color="Color.Error" Class="mt-1">@Loc.T("brewform.no_coffee_hint")</MudText>
            }
        </MudPaper>

        <MudPaper Class="pa-4" Elevation="0">
            <MudGrid Spacing="2">
                <MudItem xs="6">
                    <MudDatePicker @bind-Date="_date" Label="@Loc.T("brewform.field_date")" Variant="Variant.Outlined" Editable="true" />
                </MudItem>
                <MudItem xs="6">
                    <MudTimePicker @bind-Time="_time" Label="@Loc.T("brewform.field_time")" Variant="Variant.Outlined" Editable="true" />
                </MudItem>
            </MudGrid>
            <MudSelect T="BrewMethod" Value="_model.Method" ValueChanged="OnMethodChanged"
                       Label="@Loc.T("brewform.field_method")" Variant="Variant.Outlined" Class="mt-3">
                @foreach (var m in Enum.GetValues<BrewMethod>())
                {
                    <MudSelectItem T="BrewMethod" Value="@m">@m.GetLabel()</MudSelectItem>
                }
            </MudSelect>
        </MudPaper>

        @{ var brewers = CurrentBrewers(); }
        <MudPaper Class="pa-4" Elevation="0">
            <MudText Typo="Typo.overline" Class="mud-text-secondary mb-2">@Loc.T("brewform.section_machines")</MudText>

            <MudSelect T="int?" @bind-Value="_model.BrewerMachineId" Label="@BrewerLabel()"
                       Variant="Variant.Outlined" Clearable="true" Class="mb-3">
                <MudSelectItem T="int?" Value="@((int?)null)">@Loc.T("brewform.field_machine_none")</MudSelectItem>
                @foreach (var m in brewers)
                {
                    <MudSelectItem T="int?" Value="@m.Id">@m.Name <span class="mud-text-secondary" style="font-size:11px;">· @m.Type.GetLabel()</span></MudSelectItem>
                }
            </MudSelect>
            @if (brewers.Count == 0)
            {
                <MudText Typo="Typo.caption" Class="mud-text-secondary mb-3 d-block" Style="margin-top:-8px;">
                    @Loc.T("brewform.no_brewer_hint")
                </MudText>
            }

            <MudSelect T="int?" @bind-Value="_model.GrinderId" Label="@Loc.T("brewform.field_grinder")"
                       Variant="Variant.Outlined" Clearable="true">
                <MudSelectItem T="int?" Value="@((int?)null)">@Loc.T("brewform.field_grinder_none")</MudSelectItem>
                @foreach (var m in _grinders)
                {
                    <MudSelectItem T="int?" Value="@m.Id">@m.Name</MudSelectItem>
                }
            </MudSelect>
            @if (_grinders.Count == 0)
            {
                <MudText Typo="Typo.caption" Class="mud-text-secondary d-block" Style="margin-top:4px;">
                    @Loc.T("brewform.no_grinder_hint")
                </MudText>
            }
        </MudPaper>

        <MudPaper Class="pa-4" Elevation="0">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.overline" Class="mud-text-secondary mb-2">@Loc.T("brewform.section_score")</MudText>
                    <StarRating Value="@_model.Rating" ValueChanged="@((int v) => _model.Rating = v)" Size="Size.Large" />
                </div>
                <MudIconButton
                    Icon="@(_model.IsFavorite ? Icons.Material.Filled.Favorite : Icons.Material.Filled.FavoriteBorder)"
                    Color="@(_model.IsFavorite ? Color.Error : Color.Default)"
                    Size="Size.Large"
                    OnClick="@(() => _model.IsFavorite = !_model.IsFavorite)"
                    aria-label="@Loc.T("brewform.fav_aria")" />
            </div>
        </MudPaper>

        <MudPaper Class="pa-4" Elevation="0">
            <MudText Typo="Typo.overline" Class="mud-text-secondary mb-2">@Loc.T("brewform.section_recipe")</MudText>

            <MudText Typo="Typo.caption" Class="mud-text-secondary mb-1 d-block">@Loc.T("brewform.field_target_ratio")</MudText>
            <div class="d-flex flex-wrap mb-3" style="gap:6px;">
                @foreach (var preset in _ratioPresets)
                {
                    <MudChip T="string" Size="Size.Small"
                             Variant="@(_targetRatio == preset.Value ? Variant.Filled : Variant.Outlined)"
                             Color="@(_targetRatio == preset.Value ? Color.Primary : Color.Default)"
                             OnClick="@(() => SetRatio(preset.Value, preset.Label))">
                        @preset.Label
                    </MudChip>
                }
                <MudChip T="string" Size="Size.Small"
                         Variant="@(_targetRatio is null ? Variant.Filled : Variant.Outlined)"
                         Color="@(_targetRatio is null ? Color.Primary : Color.Default)"
                         OnClick="@(() => SetRatio(null, null))">
                    @Loc.T("brewform.field_ratio_none")
                </MudChip>
            </div>

            <MudGrid Spacing="2">
                <MudItem xs="6">
                    <MudNumericField T="decimal?" Value="_model.DoseG"
                                     ValueChanged="OnDoseChanged"
                                     Label="@Loc.T("brewform.field_dose")" Variant="Variant.Outlined"
                                     Format="0.#" Culture="@_inv" Min="0m" Immediate="true" />
                </MudItem>
                <MudItem xs="6">
                    <MudTextField Value="@YieldDisplay"
                                  Label="@Loc.T("brewform.field_yield")" Variant="Variant.Outlined"
                                  ReadOnly="true"
                                  HelperText="@YieldHint" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_model.GrindSize" Label="@Loc.T("brewform.field_grind")"
                                  Variant="Variant.Outlined" Placeholder="@Loc.T("brewform.field_grind_placeholder")" />
                </MudItem>
                <MudItem xs="12">
                    <MudSelect T="MilkType?" @bind-Value="_model.Milk"
                               Label="@Loc.T("brewform.field_milk")" Variant="Variant.Outlined" Clearable="true">
                        <MudSelectItem T="MilkType?" Value="@((MilkType?)null)">@Loc.T("brewform.field_milk_none")</MudSelectItem>
                        @foreach (var m in Enum.GetValues<MilkType>())
                        {
                            <MudSelectItem T="MilkType?" Value="@m">@m.GetLabel()</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
            </MudGrid>
        </MudPaper>

        <MudPaper Class="pa-4" Elevation="0">
            <MudTextField @bind-Value="_model.Notes" Label="@Loc.T("brewform.field_notes")" Variant="Variant.Outlined" Lines="4" Placeholder="@Loc.T("brewform.field_notes_placeholder")" />
        </MudPaper>

        <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Size="Size.Large"
                   StartIcon="@Icons.Material.Filled.Save" Disabled="_saving">
            @(IsEdit ? Loc.T("common.save") : Loc.T("brewform.btn_create"))
        </MudButton>

        @if (IsEdit)
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" FullWidth="true"
                       StartIcon="@Icons.Material.Filled.Replay"
                       OnClick="@(() => Nav.NavigateTo($"brews/new?fromBrewId={Id}"))">
                @Loc.T("brewform.btn_redo")
            </MudButton>

            <MudButton Variant="Variant.Filled" Color="Color.Error" FullWidth="true"
                       StartIcon="@Icons.Material.Filled.Delete" OnClick="DeleteAsync">@Loc.T("common.delete")</MudButton>
        }

    </MudStack>
</EditForm>

@code {
    [Parameter] public int? Id { get; set; }
    [SupplyParameterFromQuery] public int? CoffeeId { get; set; }
    [SupplyParameterFromQuery] public int? FromBrewId { get; set; }

    private bool IsEdit => Id is not null;
    private Brew _model = new();
    private DateTime? _date = DateTime.Today;
    private TimeSpan? _time = DateTime.Now.TimeOfDay;
    private List<Coffee> _coffees = new();
    private List<Machine> _allBrewers = new();
    private List<Machine> _grinders = new();
    private bool _saving;
    private readonly System.Globalization.CultureInfo _inv = System.Globalization.CultureInfo.InvariantCulture;

    private decimal? _targetRatio;
    private readonly (string Label, decimal Value)[] _ratioPresets =
    {
        ("1:1.5", 1.5m),
        ("1:2", 2m),
        ("1:2.5", 2.5m),
        ("1:3", 3m),
        ("1:15", 15m),
        ("1:16", 16m),
        ("1:17", 17m)
    };

    private string YieldDisplay => _model.YieldG is decimal y ? y.ToString("0.#", _inv) : "—";

    private string? YieldHint
    {
        get
        {
            if (_targetRatio is null) return Loc.T("brewform.yield_hint_no_ratio");
            if (_model.DoseG is null or 0m) return Loc.T("brewform.yield_hint_no_dose");
            return Loc.T("brewform.yield_hint_auto", _model.Ratio ?? "");
        }
    }

    private void SetRatio(decimal? value, string? label)
    {
        _targetRatio = value;
        _model.Ratio = label;
        Recompute();
    }

    private void OnDoseChanged(decimal? dose)
    {
        _model.DoseG = dose;
        Recompute();
    }

    private void Recompute()
    {
        if (_targetRatio is decimal r && _model.DoseG is decimal d && d > 0m)
        {
            _model.YieldG = Math.Round(d * r, 1);
        }
        else
        {
            _model.YieldG = null;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        Loc.LanguageChanged += OnLangChanged;
        // Charges qui ne dépendent pas des paramètres de route — une seule fois.
        // Pour un brew on ne propose que les cafés possédés (avec stock potentiel) ;
        // les cafés « dégustés » ne se brassent pas à la maison.
        var allCoffees = await Db.Coffees.OrderBy(nameof(Coffee.CreatedAt)).Reverse().ToList();
        _coffees = allCoffees.Where(c => c.IsOwned).ToList();

        var allMachines = await Db.Machines.ToCollection().ToList();
        _allBrewers = allMachines.Where(m => m.Type.IsBrewer()).ToList();
        _grinders = allMachines.Where(m => m.Type == MachineType.Grinder).ToList();
    }

    private void OnLangChanged() => InvokeAsync(StateHasChanged);
    public void Dispose() => Loc.LanguageChanged -= OnLangChanged;

    protected override async Task OnParametersSetAsync()
    {
        // ─── Reset complet à chaque changement de paramètres ───
        // Indispensable car Blazor réutilise l'instance du composant entre
        // /brews/{Id}/edit et /brews/new (même @page racine), donc les
        // field-initializers (_model = new(), _date = Today, _time = Now)
        // ne sont PAS rejoués. Sans ce reset, la date/heure et le modèle
        // du brew précédent persistent quand on clique « Refaire ».
        var now = DateTime.Now;
        _model = new();
        _date = now.Date;
        _time = now.TimeOfDay;
        _targetRatio = null;

        if (IsEdit)
        {
            var b = await Db.Brews.Get(Id!.Value);
            if (b is not null)
            {
                _model = b;
                _date = b.Date.Date;
                _time = b.Date.TimeOfDay;
                _targetRatio = ParseRatio(_model.Ratio);
            }
        }
        else if (FromBrewId is not null)
        {
            // Refaire un brew : copie la recette mais garde la date/heure « maintenant »
            // (un redo est un nouvel événement à l'instant t, pas une copie temporelle).
            var src = await Db.Brews.Get(FromBrewId.Value);
            if (src is not null)
            {
                _model.CoffeeId = src.CoffeeId;
                _model.Method = src.Method;
                _model.DoseG = src.DoseG;
                _model.YieldG = src.YieldG;
                _model.Ratio = src.Ratio;
                _model.GrindSize = src.GrindSize;
                _model.Notes = src.Notes;
                _model.BrewerMachineId = src.BrewerMachineId;
                _model.GrinderId = src.GrinderId;
                _model.Milk = src.Milk;
                _targetRatio = ParseRatio(_model.Ratio);
            }
        }
        else if (CoffeeId is not null)
        {
            _model.CoffeeId = CoffeeId.Value;
        }
    }

    private decimal? ParseRatio(string? label)
    {
        if (string.IsNullOrWhiteSpace(label)) return null;
        var preset = _ratioPresets.FirstOrDefault(p => p.Label == label);
        if (preset.Value != 0m) return preset.Value;
        // Best-effort parse for legacy strings like "1:2.5"
        var parts = label.Split(':');
        if (parts.Length == 2 && decimal.TryParse(parts[1].Trim(), System.Globalization.NumberStyles.Any, _inv, out var v))
            return v;
        return null;
    }

    private List<Machine> CurrentBrewers()
    {
        var t = MachineTypeOrder.BrewerTypeFor(_model.Method);
        return t is null ? _allBrewers : _allBrewers.Where(m => m.Type == t.Value).ToList();
    }

    private string BrewerLabel()
    {
        var t = MachineTypeOrder.BrewerTypeFor(_model.Method);
        return t is null ? Loc.T("brewform.field_machine") : Loc.T("brewform.field_machine_typed", t.Value.GetLabel());
    }

    private void OnMethodChanged(BrewMethod m)
    {
        _model.Method = m;
        // Si la machine actuellement sélectionnée n'est plus compatible, on la désélectionne.
        if (_model.BrewerMachineId is int id && CurrentBrewers().All(b => b.Id != id))
        {
            _model.BrewerMachineId = null;
        }
    }

    private async Task SaveAsync()
    {
        _saving = true;
        try
        {
            var d = _date ?? DateTime.Today;
            var t = _time ?? TimeSpan.Zero;
            _model.Date = d.Date.Add(t);
            if (string.IsNullOrWhiteSpace(_model.Ratio)) _model.Ratio = null;

            if (IsEdit)
            {
                _model.Id = Id!.Value;
                await Db.Brews.Put(_model);
                Snackbar.Add(Loc.T("brewform.snack_saved"), Severity.Success);
            }
            else
            {
                _model.CreatedAt = DateTime.UtcNow;
                _model.Id = 0;
                await Db.Brews.Add(_model);
                Snackbar.Add(Loc.T("brewform.snack_created"), Severity.Success);
            }
            Sync.RequestPush();
            Nav.NavigateTo("brews");
        }
        catch (Exception ex)
        {
            Snackbar.Add(Loc.T("common.error_prefix", ex.Message), Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task DeleteAsync()
    {
        var ok = await Dialogs.ShowMessageBoxAsync(new MessageBoxOptions
        {
            Title = Loc.T("brewform.delete_title"),
            Message = Loc.T("brewform.delete_msg"),
            YesText = Loc.T("common.delete"),
            CancelText = Loc.T("common.cancel")
        });
        if (ok != true || Id is null) return;
        await Db.Brews.Delete(Id.Value);
        Sync.RequestPush();
        Snackbar.Add(Loc.T("brewform.snack_deleted"), Severity.Info);
        Nav.NavigateTo("brews");
    }
}
