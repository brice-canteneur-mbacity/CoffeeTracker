@*
    Liste des Shops (entité, depuis DB v5). Chaque ligne agrège : nb de visites, note moyenne,
    date de dernière visite, photo dérivée du shop ou de la visite la + récente.
    Toggle vue liste / vue carte (Leaflet, 1 marker par shop). Click sur une carte → /shops/{id}.
*@
@page "/shops"
@implements IAsyncDisposable
@inject CoffeeDb Db
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Coffee shops</PageTitle>

<PageHeader Title="Coffee shops"
            Subtitle="@($"{_aggregates.Count} shop{(_aggregates.Count > 1 ? "s" : "")} · {_totalVisits} visite{(_totalVisits > 1 ? "s" : "")}")">
    <Action>
        <MudIconButton Icon="@(_mapMode ? Icons.Material.Filled.ViewList : Icons.Material.Filled.Map)"
                       Size="Size.Medium"
                       OnClick="@(() => _mapMode = !_mapMode)"
                       aria-label="@(_mapMode ? "Vue liste" : "Vue carte")" />
        <MudIconButton Icon="@Icons.Material.Filled.Add"
                       Color="Color.Primary"
                       Variant="Variant.Filled"
                       Size="Size.Medium"
                       OnClick="@(() => Nav.NavigateTo("shops/new"))" />
    </Action>
</PageHeader>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-4" />
}
else
{
    <MudTextField @bind-Value="_search" Placeholder="Rechercher (nom, ville…)"
                  Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-3"
                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                  Clearable="true" Immediate="true" DebounceInterval="150" />

    var filtered = Filter(_aggregates);
    var hasSearch = !string.IsNullOrWhiteSpace(_search);
    var withCoords = filtered.Count(a => a.Shop.Latitude is not null && a.Shop.Longitude is not null);

    if (_mapMode)
    {
        <div id="@MapElementId" class="shops-map"></div>
        if (filtered.Count == 0)
        {
            <MudText Typo="Typo.caption" Class="mud-text-secondary mt-2 d-block text-center">
                Aucun shop à afficher.
            </MudText>
        }
        else if (withCoords == 0)
        {
            <MudText Typo="Typo.caption" Class="mud-text-secondary mt-2 d-block text-center">
                Aucun des @filtered.Count shop(s) n'a de coordonnées GPS — utilise « Rechercher en ligne » sur le formulaire shop pour les géolocaliser.
            </MudText>
        }
        else if (withCoords < filtered.Count)
        {
            <MudText Typo="Typo.caption" Class="mud-text-secondary mt-2 d-block text-center">
                @withCoords sur @filtered.Count shop(s) localisés sur la carte.
            </MudText>
        }
    }
    else if (filtered.Count == 0)
    {
        <MudPaper Class="pa-8 d-flex flex-column align-center" Elevation="0">
            <MudIcon Icon="@Icons.Material.Filled.Storefront" Size="Size.Large" Class="mb-3" Style="color: var(--coffee-accent-soft)" />
            @if (hasSearch)
            {
                <MudText Typo="Typo.h6">Aucun résultat</MudText>
                <MudText Class="mud-text-secondary">pour « @_search »</MudText>
            }
            else
            {
                <MudText Typo="Typo.h6">Aucun shop encore</MudText>
                <MudText Class="mb-4 mud-text-secondary">Ajoute un shop pour suivre tes visites.</MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="@(() => Nav.NavigateTo("shops/new"))">Ajouter un shop</MudButton>
            }
        </MudPaper>
    }
    else
    {
    <MudStack Spacing="2">
        @foreach (var a in filtered)
        {
            <MudPaper Class="pa-3 shop-card" Elevation="0"
                      @onclick="@(() => Nav.NavigateTo($"shops/{a.Shop.Id}"))">
                <div class="d-flex" style="gap:12px;">
                    @if (!string.IsNullOrEmpty(a.PhotoDataUrl))
                    {
                        <img src="@a.PhotoDataUrl" alt="" class="thumb-md" />
                    }
                    else
                    {
                        <div class="thumb-md thumb-placeholder">
                            <MudIcon Icon="@Icons.Material.Filled.Storefront" />
                        </div>
                    }
                    <div style="flex:1; min-width:0;">
                        <div class="d-flex align-start justify-space-between" style="gap:8px;">
                            <MudText Style="font-weight:600;" Class="text-truncate">@a.Shop.Name</MudText>
                            @if (a.VisitCount > 0)
                            {
                                <StarRating Value="@((int)Math.Round(a.AverageRating))" ReadOnly="true" Size="Size.Small" />
                            }
                        </div>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary mt-1">
                            @if (!string.IsNullOrEmpty(a.Shop.City) || !string.IsNullOrEmpty(a.Shop.Country))
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Place" Size="Size.Small" />
                                <span>@(string.Join(", ", new[] { a.Shop.City, a.Shop.Country }.Where(s => !string.IsNullOrEmpty(s))))</span>
                                <span> · </span>
                            }
                            <span>
                                @if (a.VisitCount == 0)
                                {
                                    <span>Aucune visite</span>
                                }
                                else
                                {
                                    <span>@a.VisitCount visite@(a.VisitCount > 1 ? "s" : "")</span>
                                    @if (a.LastVisitDate is DateOnly d)
                                    {
                                        <span> · dernière le @Format.Date(d)</span>
                                    }
                                }
                            </span>
                        </MudText>
                    </div>
                </div>
            </MudPaper>
        }
    </MudStack>
    }
}

<style>
    .shop-card { border: 1px solid var(--coffee-border); cursor: pointer; transition: transform .08s; }
    .shop-card:active { transform: scale(.99); }
    .thumb-md { width: 56px; height: 56px; border-radius: 12px; flex-shrink: 0; object-fit: cover; }
    .thumb-placeholder { background: var(--coffee-surface-soft); display: flex; align-items: center; justify-content: center; color: var(--coffee-accent-soft); }
    .shops-map {
        height: calc(100vh - 260px);
        min-height: 320px;
        border-radius: 16px;
        overflow: hidden;
        border: 1px solid var(--coffee-border);
    }
    .shops-map .leaflet-container { font-family: inherit; }
</style>

@code {
    private const string MapElementId = "shops-map";

    private bool _loading = true;
    private List<ShopAggregate> _aggregates = new();
    private int _totalVisits;
    private string _search = string.Empty;
    private bool _mapMode;
    private bool _mapInitialized;

    private record ShopAggregate(
        Shop Shop,
        int VisitCount,
        double AverageRating,
        DateOnly? LastVisitDate,
        string? PhotoDataUrl);

    private List<ShopAggregate> Filter(List<ShopAggregate> list)
    {
        if (string.IsNullOrWhiteSpace(_search)) return list;
        var q = _search.Trim();
        var sc = StringComparison.OrdinalIgnoreCase;
        return list.Where(a =>
            a.Shop.Name.Contains(q, sc)
            || (a.Shop.City?.Contains(q, sc) ?? false)
            || (a.Shop.Country?.Contains(q, sc) ?? false)
            || (a.Shop.Address?.Contains(q, sc) ?? false)
        ).ToList();
    }

    protected override async Task OnInitializedAsync()
    {
        var shops = await Db.Shops.ToCollection().ToList();
        var visits = await Db.ShopVisits.ToCollection().ToList();
        _totalVisits = visits.Count;

        var visitsByShop = visits
            .GroupBy(v => v.ShopId)
            .ToDictionary(g => g.Key, g => g.ToList());

        _aggregates = shops
            .Select(s =>
            {
                var vs = visitsByShop.TryGetValue(s.Id, out var list) ? list : new List<CoffeeShopVisit>();
                var avg = vs.Count > 0 ? vs.Average(v => v.Rating) : 0;
                var last = vs.Count > 0 ? vs.Max(v => v.Date) : (DateOnly?)null;
                var photo = !string.IsNullOrEmpty(s.PhotoDataUrl)
                    ? s.PhotoDataUrl
                    : vs.OrderByDescending(v => v.Date)
                        .Select(v => v.PhotoDataUrl)
                        .FirstOrDefault(p => !string.IsNullOrEmpty(p));
                return new ShopAggregate(s, vs.Count, avg, last, photo);
            })
            // Tri : shops avec visites récentes d'abord, puis sans visite par création récente.
            .OrderByDescending(a => a.LastVisitDate ?? DateOnly.MinValue)
            .ThenByDescending(a => a.Shop.CreatedAt)
            .ToList();

        _loading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_loading) return;

        if (_mapMode)
        {
            var markers = Filter(_aggregates).Select(a => new
            {
                id = a.Shop.Id,
                shopName = a.Shop.Name,
                city = a.Shop.City,
                visitCount = a.VisitCount,
                rating = a.VisitCount > 0 ? (int)Math.Round(a.AverageRating) : 0,
                latitude = a.Shop.Latitude,
                longitude = a.Shop.Longitude,
                lastVisitLabel = a.LastVisitDate is DateOnly d ? Format.Date(d) : null
            }).ToArray();

            if (!_mapInitialized)
            {
                await JS.InvokeVoidAsync("coffeeMap.init", MapElementId, markers);
                _mapInitialized = true;
            }
            else
            {
                await JS.InvokeVoidAsync("coffeeMap.update", MapElementId, markers);
            }
        }
        else if (_mapInitialized)
        {
            try { await JS.InvokeVoidAsync("coffeeMap.destroy", MapElementId); } catch { }
            _mapInitialized = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_mapInitialized)
        {
            try { await JS.InvokeVoidAsync("coffeeMap.destroy", MapElementId); } catch { }
            _mapInitialized = false;
        }
    }
}
