@*
    Page Réglages. Sections :
    - Apparence : préférence light/dark/system (ThemeService)
    - Sync GitHub Gist : configuration du PAT, sync manuelle, déconnexion (SyncService)
    - Sauvegarde locale : export/import JSON (CoffeeBackup, version 4)
    - Notifications : permission + préférence utilisateur (AlertsService)
    - Recherche shops : clé Google API (optionnelle, sinon fallback OSM)
    - Diagnostic & maintenance : état migrations + bouton manuel « Reconstruire les shops »
    - Zone dangereuse : tout effacer
*@
@page "/settings"
@using System.Text.Json
@using System.Text.Json.Serialization
@implements IDisposable
@inject CoffeeDb Db
@inject IJSRuntime JS
@inject ISnackbar Snackbar
@inject IDialogService Dialogs
@inject PlaceSearchService PlaceSearch
@inject ThemeService Theme
@inject SyncService Sync
@inject AlertsService Alerts
@inject MigrationService Migrations

<PageTitle>Réglages</PageTitle>

<PageHeader Title="Réglages" Back="true" BackUrl="stats" />

<MudStack Spacing="3">

    <MudPaper Class="pa-4" Elevation="0">
        <MudText Typo="Typo.h6" Class="mb-1">Apparence</MudText>
        <MudText Typo="Typo.body2" Class="mud-text-secondary mb-3">
            « Système » suit le réglage de ton OS. Sinon force clair ou sombre.
        </MudText>
        <MudRadioGroup T="string" Value="@Theme.Preference" ValueChanged="OnThemeChanged">
            <MudRadio T="string" Value="@("system")" Color="Color.Primary">Système</MudRadio>
            <MudRadio T="string" Value="@("light")" Color="Color.Primary">Clair</MudRadio>
            <MudRadio T="string" Value="@("dark")" Color="Color.Primary">Sombre</MudRadio>
        </MudRadioGroup>
    </MudPaper>

    <MudPaper Class="pa-4" Elevation="0">
        <MudText Typo="Typo.h6" Class="mb-1">Sync entre appareils (GitHub Gist)</MudText>
        <MudText Typo="Typo.body2" Class="mud-text-secondary mb-3">
            Stocke tes données dans un Gist privé sur GitHub. Configure le même token sur tes autres
            appareils pour synchroniser. Crée un
            <MudLink Href="https://github.com/settings/tokens?type=beta" Target="_blank">token GitHub</MudLink>
            avec uniquement le scope <code>gist</code>.
        </MudText>

        <MudTextField @bind-Value="_pat" Label="GitHub Personal Access Token"
                      Variant="Variant.Outlined" InputType="InputType.Password"
                      Placeholder="github_pat_…" Class="mb-2" />

        <div class="d-flex flex-wrap mb-3" style="gap:8px;">
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Save"
                       OnClick="SavePatAsync" Disabled="Sync.IsBusy">
                Enregistrer le token
            </MudButton>
            @if (Sync.IsConfigured)
            {
                <MudButton Variant="Variant.Filled" Color="Color.Tertiary"
                           StartIcon="@Icons.Material.Filled.Sync"
                           OnClick="SyncNowAsync" Disabled="Sync.IsBusy">
                    @(Sync.IsBusy ? "Synchronisation…" : "Synchroniser maintenant")
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Default"
                           StartIcon="@Icons.Material.Filled.LinkOff"
                           OnClick="DisconnectSyncAsync" Disabled="Sync.IsBusy">
                    Déconnecter
                </MudButton>
            }
        </div>

        @if (Sync.IsConfigured)
        {
            <MudText Typo="Typo.caption" Class="mud-text-secondary d-block">
                @if (Sync.LastSync is DateTime ls)
                {
                    <span>✓ Dernière sync : @ls.ToLocalTime().ToString("dd MMM, HH:mm")</span>
                }
                else
                {
                    <span>Pas encore synchronisé. Clique « Synchroniser maintenant » pour pousser les données et créer le Gist privé.</span>
                }
                @if (!string.IsNullOrEmpty(Sync.GistId))
                {
                    <br/>
                    <span>Gist : <code>@Sync.GistId</code></span>
                }
            </MudText>
        }

        @if (!string.IsNullOrEmpty(Sync.LastInfo))
        {
            <MudAlert Severity="Severity.Success" Dense="true" Class="mt-2">@Sync.LastInfo</MudAlert>
        }
        @if (!string.IsNullOrEmpty(Sync.LastError))
        {
            <MudAlert Severity="Severity.Error" Dense="true" Class="mt-2">@Sync.LastError</MudAlert>
        }

        <MudText Typo="Typo.caption" Class="mud-text-secondary d-block mt-3" Style="font-style:italic;">
            ⚠️ Stratégie last-write-wins : « Synchroniser » fait d'abord un pull (écrase tes données locales par celles du Gist), puis push tes données. Pour usage solo multi-appareils, utilise le bouton sur le device le plus à jour avant de basculer.
        </MudText>
    </MudPaper>

    <MudPaper Class="pa-4" Elevation="0">
        <MudText Typo="Typo.h6" Class="mb-1">Sauvegarde locale</MudText>
        <MudText Typo="Typo.body2" Class="mud-text-secondary mb-3">
            Tes données sont stockées localement dans ton navigateur. Exporte régulièrement
            pour ne rien perdre en cas de réinstallation ou de changement d'appareil.
        </MudText>

        <MudStack Spacing="2">
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Download"
                       OnClick="ExportAsync" Disabled="_busy">
                Exporter en JSON
            </MudButton>

            <div>
                <InputFile id="importInput" OnChange="OnImportFileSelectedAsync"
                           accept="application/json" style="display:none;" />
                <label for="importInput" class="upload-button" style="padding: 10px 16px; font-size: 14px;">
                    <MudIcon Icon="@Icons.Material.Filled.Upload" Size="Size.Small" />
                    <span>Importer un fichier JSON…</span>
                </label>
            </div>
        </MudStack>
    </MudPaper>

    <MudPaper Class="pa-4" Elevation="0">
        <MudText Typo="Typo.h6" Class="mb-1">Notifications</MudText>
        <MudText Typo="Typo.body2" Class="mud-text-secondary mb-3">
            Rappels affichés à l'ouverture de l'app : stock bas (≤ 30 g), sac vide,
            café au-delà du pic de dégazage (> 35 j).
            Si activé et autorisé par le navigateur, tu reçois aussi une notification système.
        </MudText>
        @if (!_notifSupported)
        {
            <MudAlert Severity="Severity.Info" Dense="true">Ton navigateur ne supporte pas l'API Notifications.</MudAlert>
        }
        else
        {
            <MudSwitch T="bool" Value="@_notifEnabled" ValueChanged="OnToggleNotifsAsync"
                       Color="Color.Primary"
                       Label="@(_notifEnabled ? "Activées" : "Désactivées")" />
            <MudText Typo="Typo.caption" Class="mud-text-secondary d-block mt-1">
                Permission navigateur :
                <strong>@_notifPermission</strong>
                @if (_notifPermission == "denied")
                {
                    <span> — débloque dans les réglages du navigateur si tu changes d'avis.</span>
                }
            </MudText>
        }
    </MudPaper>

    <MudPaper Class="pa-4" Elevation="0">
        <MudText Typo="Typo.h6" Class="mb-1">Recherche de coffee shops</MudText>
        <MudText Typo="Typo.body2" Class="mud-text-secondary mb-3">
            Sans clé : on utilise OpenStreetMap (gratuit, données moins riches).
            Avec une clé Google Maps Platform : Google Places (plus précis, photos potentielles).
            Le quota gratuit Google (200 $/mois de crédit) couvre largement un usage perso.
            <MudLink Href="https://developers.google.com/maps/documentation/javascript/get-api-key"
                     Target="_blank">Obtenir une clé</MudLink>.
            Pense à restreindre la clé par HTTP referrer dans la console Google Cloud.
        </MudText>
        <MudTextField @bind-Value="_googleKey" Label="Clé API Google (optionnelle)"
                      Variant="Variant.Outlined" InputType="InputType.Password"
                      Placeholder="AIzaSy…" />
        <div class="d-flex mt-2" style="gap:8px;">
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Save"
                       OnClick="SaveGoogleKeyAsync" Disabled="_busy">Enregistrer</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Default"
                       StartIcon="@Icons.Material.Filled.Clear"
                       OnClick="ClearGoogleKeyAsync" Disabled="_busy">Effacer</MudButton>
        </div>
    </MudPaper>

    <MudPaper Class="pa-4" Elevation="0">
        <MudText Typo="Typo.h6" Class="mb-1">Diagnostic & maintenance</MudText>
        <MudText Typo="Typo.body2" Class="mud-text-secondary mb-3">
            Si tes anciennes visites n'apparaissent pas dans la liste des shops, lance un diagnostic
            puis « Reconstruire les shops » pour relancer la migration.
        </MudText>

        @if (_diag is not null)
        {
            <MudPaper Class="pa-3 mb-3" Elevation="0" Style="background: var(--coffee-surface-soft);">
                <MudText Typo="Typo.caption" Class="d-block">
                    <strong>Visites :</strong> @_diag.VisitCount ·
                    <strong>Shops :</strong> @_diag.ShopCount ·
                    <strong>Visites non reliées :</strong> @_diag.PendingVisitCount
                    @if (_diag.OrphanVisitCount > 0)
                    {
                        <span> · <strong>Orphelines :</strong> @_diag.OrphanVisitCount</span>
                    }
                </MudText>
                @if (_diag.PendingPreview.Count > 0)
                {
                    <MudText Typo="Typo.caption" Class="mud-text-secondary mt-2 d-block">
                        À migrer (aperçu) :
                        @foreach (var p in _diag.PendingPreview)
                        {
                            <span class="d-block ml-2">• @p</span>
                        }
                    </MudText>
                }
            </MudPaper>
        }

        <div class="d-flex flex-wrap" style="gap:8px;">
            <MudButton Variant="Variant.Outlined" Color="Color.Default"
                       StartIcon="@Icons.Material.Filled.Search"
                       OnClick="DiagnoseAsync" Disabled="_busy">
                Diagnostiquer
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Build"
                       OnClick="RebuildShopsAsync" Disabled="_busy">
                Reconstruire les shops
            </MudButton>
        </div>

        @if (!string.IsNullOrEmpty(_migrationStatus))
        {
            <MudText Typo="Typo.caption" Class="mt-2 d-block" Style="white-space:pre-wrap;">@_migrationStatus</MudText>
        }
    </MudPaper>

    <MudPaper Class="pa-4" Elevation="0">
        <MudText Typo="Typo.h6" Class="mb-1">Zone dangereuse</MudText>
        <MudText Typo="Typo.body2" Class="mud-text-secondary mb-3">
            Supprime toutes les données de l'application (cafés, brews, visites). Irréversible.
        </MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Error"
                   StartIcon="@Icons.Material.Filled.DeleteForever"
                   OnClick="EraseAllAsync" Disabled="_busy">
            Tout effacer
        </MudButton>
    </MudPaper>

</MudStack>

@code {
    private bool _busy;
    private string? _googleKey;
    private string? _pat;
    private bool _notifSupported;
    private bool _notifEnabled;
    private string _notifPermission = "default";
    private MigrationDiagnostic? _diag;
    private string? _migrationStatus;

    protected override async Task OnInitializedAsync()
    {
        _googleKey = await PlaceSearch.GetGoogleKeyAsync();
        _pat = Sync.Pat;
        Sync.StateChanged += OnSyncChanged;

        _notifSupported = await Alerts.IsSupportedAsync();
        if (_notifSupported)
        {
            _notifEnabled = await Alerts.IsEnabledAsync();
            _notifPermission = await Alerts.GetPermissionAsync();
        }
    }

    private async Task OnToggleNotifsAsync(bool enabled)
    {
        if (enabled)
        {
            // Demande la permission au navigateur si pas encore accordée
            var granted = await Alerts.RequestPermissionAsync();
            _notifPermission = await Alerts.GetPermissionAsync();
            if (!granted)
            {
                Snackbar.Add("Permission notifications refusée par le navigateur", Severity.Warning);
                _notifEnabled = false;
                return;
            }
        }
        await Alerts.SetEnabledAsync(enabled);
        _notifEnabled = enabled;
        Snackbar.Add(enabled ? "Notifications activées" : "Notifications désactivées", Severity.Success);
    }

    private void OnSyncChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => Sync.StateChanged -= OnSyncChanged;

    private async Task SavePatAsync()
    {
        await Sync.SetPatAsync(_pat);
        Snackbar.Add(string.IsNullOrWhiteSpace(_pat) ? "Token effacé" : "Token enregistré", Severity.Success);
    }

    private async Task SyncNowAsync()
    {
        var ok = await Sync.SyncAsync();
        if (ok) Snackbar.Add("Synchronisation OK", Severity.Success);
        else if (!string.IsNullOrEmpty(Sync.LastError)) Snackbar.Add(Sync.LastError, Severity.Error);
    }

    private async Task DisconnectSyncAsync()
    {
        var ok = await Dialogs.ShowMessageBoxAsync(new MessageBoxOptions
        {
            Title = "Déconnecter la sync ?",
            Message = "Le token et l'identifiant Gist seront effacés sur cet appareil. Tes données locales restent intactes. Le Gist sur GitHub n'est pas supprimé (tu peux le faire manuellement si besoin).",
            YesText = "Déconnecter",
            CancelText = "Annuler"
        });
        if (ok != true) return;
        await Sync.DisconnectAsync();
        _pat = null;
        Snackbar.Add("Sync déconnectée", Severity.Info);
    }

    private async Task SaveGoogleKeyAsync()
    {
        _busy = true;
        try
        {
            await PlaceSearch.SetGoogleKeyAsync(_googleKey);
            Snackbar.Add(string.IsNullOrWhiteSpace(_googleKey) ? "Clé effacée" : "Clé enregistrée", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erreur : {ex.Message}", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task ClearGoogleKeyAsync()
    {
        _googleKey = null;
        await PlaceSearch.SetGoogleKeyAsync(null);
        Snackbar.Add("Clé effacée — passage en OpenStreetMap", Severity.Info);
    }

    private async Task OnThemeChanged(string pref)
    {
        await Theme.SetPreferenceAsync(pref);
    }

    private static readonly JsonSerializerOptions ExportOptions = new()
    {
        WriteIndented = true,
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
        DictionaryKeyPolicy = JsonNamingPolicy.CamelCase,
        Converters = { new JsonStringEnumConverter(JsonNamingPolicy.CamelCase) },
        DefaultIgnoreCondition = JsonIgnoreCondition.WhenWritingNull
    };

    private static readonly JsonSerializerOptions ImportOptions = new()
    {
        PropertyNameCaseInsensitive = true,
        Converters = { new JsonStringEnumConverter(JsonNamingPolicy.CamelCase) }
    };

    private async Task ExportAsync()
    {
        _busy = true;
        try
        {
            var coffees = await Db.Coffees.ToCollection().ToList();
            var brews = await Db.Brews.ToCollection().ToList();
            var visits = await Db.ShopVisits.ToCollection().ToList();
            var shops = await Db.Shops.ToCollection().ToList();
            var machines = await Db.Machines.ToCollection().ToList();

            var data = new ExportFile
            {
                Version = 4,
                ExportedAt = DateTime.UtcNow,
                Coffees = coffees,
                Brews = brews,
                Shops = shops,
                ShopVisits = visits,
                Machines = machines
            };

            var json = JsonSerializer.Serialize(data, ExportOptions);
            var filename = $"coffee-tracker-{DateTime.Now:yyyy-MM-dd}.json";
            await JS.InvokeVoidAsync("coffeeData.downloadJson", filename, json);

            Snackbar.Add($"Sauvegarde téléchargée ({coffees.Count} cafés, {brews.Count} brews, {shops.Count} shops, {visits.Count} visites, {machines.Count} machines)", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erreur export : {ex.Message}", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task OnImportFileSelectedAsync(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;

        string json;
        try
        {
            await using var stream = file.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024);
            using var reader = new StreamReader(stream);
            json = await reader.ReadToEndAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erreur lecture du fichier : {ex.Message}", Severity.Error);
            return;
        }

        ExportFile? parsed;
        try
        {
            parsed = JsonSerializer.Deserialize<ExportFile>(json, ImportOptions);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Fichier JSON invalide : {ex.Message}", Severity.Error);
            return;
        }

        if (parsed is null)
        {
            Snackbar.Add("Fichier JSON vide ou invalide", Severity.Error);
            return;
        }

        var summary = $"{parsed.Coffees?.Count ?? 0} cafés, {parsed.Brews?.Count ?? 0} brews, {parsed.Shops?.Count ?? 0} shops, {parsed.ShopVisits?.Count ?? 0} visites, {parsed.Machines?.Count ?? 0} machines";
        var ok = await Dialogs.ShowMessageBoxAsync(new MessageBoxOptions
        {
            Title = "Importer ?",
            Message = $"Cette opération va REMPLACER toutes tes données actuelles par {summary}. Continuer ?",
            YesText = "Importer (remplacer)",
            CancelText = "Annuler"
        });
        if (ok != true) return;

        _busy = true;
        try
        {
            await Db.Coffees.Clear();
            await Db.Brews.Clear();
            await Db.ShopVisits.Clear();
            await Db.Shops.Clear();
            await Db.Machines.Clear();

            foreach (var c in parsed.Coffees ?? new()) await Db.Coffees.Put(c);
            foreach (var b in parsed.Brews ?? new()) await Db.Brews.Put(b);
            foreach (var s in parsed.Shops ?? new()) await Db.Shops.Put(s);
            foreach (var v in parsed.ShopVisits ?? new()) await Db.ShopVisits.Put(v);
            foreach (var m in parsed.Machines ?? new()) await Db.Machines.Put(m);

            // Pour un fichier v ≤ 3 (sans Shops), la migration tournera au prochain reload
            // pour reconstruire les Shops à partir des visites.
            Snackbar.Add($"Import terminé ({summary})", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erreur import : {ex.Message}", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task DiagnoseAsync()
    {
        _busy = true;
        _migrationStatus = null;
        try
        {
            _diag = await Migrations.DiagnoseAsync();
        }
        catch (Exception ex)
        {
            _migrationStatus = $"❌ Erreur diagnostic : {ex.Message}\n{ex.GetType().Name}";
            Snackbar.Add("Diagnostic en échec — voir le message ci-dessous", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task RebuildShopsAsync()
    {
        _busy = true;
        _migrationStatus = null;
        try
        {
            var report = await Migrations.RunManualAsync();
            _diag = await Migrations.DiagnoseAsync();
            if (report.HasChanges)
            {
                _migrationStatus = $"✓ {report.ShopsCreated} shop(s) créé(s), {report.VisitsLinked} visite(s) reliée(s).";
                Snackbar.Add(_migrationStatus, Severity.Success);
            }
            else
            {
                _migrationStatus = "Rien à migrer (toutes les visites sont déjà reliées à un shop).";
                Snackbar.Add(_migrationStatus, Severity.Info);
            }
        }
        catch (Exception ex)
        {
            _migrationStatus = $"❌ Erreur migration : {ex.Message}\n{ex.GetType().Name}\n{ex.StackTrace}";
            Snackbar.Add("Migration en échec — voir le détail dans la section Diagnostic", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task EraseAllAsync()
    {
        var ok = await Dialogs.ShowMessageBoxAsync(new MessageBoxOptions
        {
            Title = "Tout effacer ?",
            Message = "Cette action supprime DÉFINITIVEMENT tous tes cafés, brews et visites. Action irréversible.",
            YesText = "Tout effacer",
            CancelText = "Annuler"
        });
        if (ok != true) return;

        _busy = true;
        try
        {
            await Db.Coffees.Clear();
            await Db.Brews.Clear();
            await Db.ShopVisits.Clear();
            await Db.Shops.Clear();
            await Db.Machines.Clear();
            Snackbar.Add("Toutes les données ont été supprimées", Severity.Info);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erreur : {ex.Message}", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private class ExportFile
    {
        public int Version { get; set; } = 4;
        public DateTime ExportedAt { get; set; }
        public List<Coffee>? Coffees { get; set; }
        public List<Brew>? Brews { get; set; }
        public List<Shop>? Shops { get; set; }
        public List<CoffeeShopVisit>? ShopVisits { get; set; }
        public List<Machine>? Machines { get; set; }
    }
}
