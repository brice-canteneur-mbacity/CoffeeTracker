@*
    Page Réglages. Sections :
    - Apparence : préférence light/dark/system (ThemeService)
    - Sync GitHub Gist : configuration du PAT, sync manuelle, déconnexion (SyncService)
    - Sauvegarde locale : export/import JSON (CoffeeBackup, version 4)
    - Notifications : permission + préférence utilisateur (AlertsService)
    - Recherche shops : clé Google API (optionnelle, sinon fallback OSM)
    - Diagnostic & maintenance : état migrations + bouton manuel « Reconstruire les shops »
    - Zone dangereuse : tout effacer
*@
@page "/settings"
@using System.Text.Json
@using System.Text.Json.Serialization
@implements IDisposable
@inject CoffeeDb Db
@inject IJSRuntime JS
@inject ISnackbar Snackbar
@inject IDialogService Dialogs
@inject PlaceSearchService PlaceSearch
@inject ThemeService Theme
@inject SyncService Sync
@inject AlertsService Alerts
@inject MigrationService Migrations
@inject LocalizationService Loc

<PageTitle>@Loc.T("settings.title")</PageTitle>

<PageHeader Title="@Loc.T("settings.title")" Back="true" BackUrl="stats" />

<MudStack Spacing="3">

    <MudPaper Class="pa-4" Elevation="0">
        <MudText Typo="Typo.h6" Class="mb-1">@Loc.T("settings.section_appearance")</MudText>
        <MudText Typo="Typo.body2" Class="mud-text-secondary mb-3">
            @Loc.T("settings.appearance_help")
        </MudText>
        <MudRadioGroup T="string" Value="@Theme.Preference" ValueChanged="OnThemeChanged">
            <MudRadio T="string" Value="@("system")" Color="Color.Primary">@Loc.T("settings.theme_system")</MudRadio>
            <MudRadio T="string" Value="@("light")" Color="Color.Primary">@Loc.T("settings.theme_light")</MudRadio>
            <MudRadio T="string" Value="@("dark")" Color="Color.Primary">@Loc.T("settings.theme_dark")</MudRadio>
        </MudRadioGroup>
    </MudPaper>

    <MudPaper Class="pa-4" Elevation="0">
        <MudText Typo="Typo.h6" Class="mb-1">@Loc.T("settings.section_language")</MudText>
        <MudText Typo="Typo.body2" Class="mud-text-secondary mb-3">
            @Loc.T("settings.language_help")
        </MudText>
        <MudRadioGroup T="string" Value="@_langValue" ValueChanged="OnLanguageChangedAsync">
            <MudRadio T="string" Value="@("auto")" Color="Color.Primary">@Loc.T("settings.language_auto")</MudRadio>
            <MudRadio T="string" Value="@("fr")" Color="Color.Primary">@Loc.T("settings.language_fr")</MudRadio>
            <MudRadio T="string" Value="@("en")" Color="Color.Primary">@Loc.T("settings.language_en")</MudRadio>
            <MudRadio T="string" Value="@("it")" Color="Color.Primary">@Loc.T("settings.language_it")</MudRadio>
        </MudRadioGroup>
    </MudPaper>

    <MudPaper Class="pa-4" Elevation="0">
        <MudText Typo="Typo.h6" Class="mb-1">@Loc.T("settings.section_sync")</MudText>
        <MudText Typo="Typo.body2" Class="mud-text-secondary mb-3">
            @Loc.T("settings.sync_help")
            <MudLink Href="https://github.com/settings/tokens?type=beta" Target="_blank">@Loc.T("settings.sync_token_link")</MudLink>
            @Loc.T("settings.sync_token_scope") <code>gist</code>.
        </MudText>

        <MudTextField @bind-Value="_pat" Label="@Loc.T("settings.sync_field_pat")"
                      Variant="Variant.Outlined" InputType="InputType.Password"
                      Placeholder="github_pat_…" Class="mb-2" />

        <div class="d-flex flex-wrap mb-3" style="gap:8px;">
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Save"
                       OnClick="SavePatAsync" Disabled="Sync.IsBusy">
                @Loc.T("settings.sync_btn_save")
            </MudButton>
            @if (Sync.IsConfigured)
            {
                <MudButton Variant="Variant.Filled" Color="Color.Tertiary"
                           StartIcon="@Icons.Material.Filled.Sync"
                           OnClick="SyncNowAsync" Disabled="Sync.IsBusy">
                    @(Sync.IsBusy ? Loc.T("settings.sync_btn_now_busy") : Loc.T("settings.sync_btn_now_idle"))
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Default"
                           StartIcon="@Icons.Material.Filled.LinkOff"
                           OnClick="DisconnectSyncAsync" Disabled="Sync.IsBusy">
                    @Loc.T("settings.sync_btn_disconnect")
                </MudButton>
            }
        </div>

        @if (Sync.IsConfigured)
        {
            <MudText Typo="Typo.caption" Class="mud-text-secondary d-block">
                @if (Sync.LastSync is DateTime ls)
                {
                    <span>@Loc.T("settings.sync_last", ls.ToLocalTime().ToString("dd MMM, HH:mm"))</span>
                }
                else
                {
                    <span>@Loc.T("settings.sync_first_time")</span>
                }
                @if (!string.IsNullOrEmpty(Sync.GistId))
                {
                    <br/>
                    <span>@Loc.T("settings.sync_gist_label") <code>@Sync.GistId</code></span>
                }
            </MudText>
        }

        @if (!string.IsNullOrEmpty(Sync.LastInfo))
        {
            <MudAlert Severity="Severity.Success" Dense="true" Class="mt-2">@Sync.LastInfo</MudAlert>
        }
        @if (!string.IsNullOrEmpty(Sync.LastError))
        {
            <MudAlert Severity="Severity.Error" Dense="true" Class="mt-2">@Sync.LastError</MudAlert>
        }

        <MudText Typo="Typo.caption" Class="mud-text-secondary d-block mt-3" Style="font-style:italic;">
            @Loc.T("settings.sync_lww_warning")
        </MudText>
    </MudPaper>

    <MudPaper Class="pa-4" Elevation="0">
        <MudText Typo="Typo.h6" Class="mb-1">@Loc.T("settings.section_backup")</MudText>
        <MudText Typo="Typo.body2" Class="mud-text-secondary mb-3">
            @Loc.T("settings.backup_help")
        </MudText>

        <MudStack Spacing="2">
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Download"
                       OnClick="ExportAsync" Disabled="_busy">
                @Loc.T("settings.btn_export")
            </MudButton>

            <div>
                <InputFile id="importInput" OnChange="OnImportFileSelectedAsync"
                           accept="application/json" style="display:none;" />
                <label for="importInput" class="upload-button" style="padding: 10px 16px; font-size: 14px;">
                    <MudIcon Icon="@Icons.Material.Filled.Upload" Size="Size.Small" />
                    <span>@Loc.T("settings.btn_import")</span>
                </label>
            </div>
        </MudStack>
    </MudPaper>

    <MudPaper Class="pa-4" Elevation="0">
        <MudText Typo="Typo.h6" Class="mb-1">@Loc.T("settings.section_notifications")</MudText>
        <MudText Typo="Typo.body2" Class="mud-text-secondary mb-3">
            @Loc.T("settings.notifications_help")
        </MudText>
        @if (!_notifSupported)
        {
            <MudAlert Severity="Severity.Info" Dense="true">@Loc.T("settings.notifications_unsupported")</MudAlert>
        }
        else
        {
            <MudSwitch T="bool" Value="@_notifEnabled" ValueChanged="OnToggleNotifsAsync"
                       Color="Color.Primary"
                       Label="@(_notifEnabled ? Loc.T("settings.notifications_enabled") : Loc.T("settings.notifications_disabled"))" />
            <MudText Typo="Typo.caption" Class="mud-text-secondary d-block mt-1">
                @Loc.T("settings.notifications_permission")
                <strong>@_notifPermission</strong>
                @if (_notifPermission == "denied")
                {
                    <span> @Loc.T("settings.notifications_permission_denied")</span>
                }
            </MudText>
        }
    </MudPaper>

    <MudPaper Class="pa-4" Elevation="0">
        <MudText Typo="Typo.h6" Class="mb-1">@Loc.T("settings.section_search")</MudText>
        <MudText Typo="Typo.body2" Class="mud-text-secondary mb-3">
            @Loc.T("settings.search_help")
            <MudLink Href="https://developers.google.com/maps/documentation/javascript/get-api-key"
                     Target="_blank">@Loc.T("settings.search_get_key")</MudLink>.
            @Loc.T("settings.search_restrict")
        </MudText>
        <MudTextField @bind-Value="_googleKey" Label="@Loc.T("settings.search_field_key")"
                      Variant="Variant.Outlined" InputType="InputType.Password"
                      Placeholder="AIzaSy…" />
        <div class="d-flex mt-2" style="gap:8px;">
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Save"
                       OnClick="SaveGoogleKeyAsync" Disabled="_busy">@Loc.T("settings.search_btn_save")</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Default"
                       StartIcon="@Icons.Material.Filled.Clear"
                       OnClick="ClearGoogleKeyAsync" Disabled="_busy">@Loc.T("settings.search_btn_clear")</MudButton>
        </div>
    </MudPaper>

    <MudPaper Class="pa-4" Elevation="0">
        <MudText Typo="Typo.h6" Class="mb-1">@Loc.T("settings.section_diagnostic")</MudText>
        <MudText Typo="Typo.body2" Class="mud-text-secondary mb-3">
            @Loc.T("settings.diagnostic_help")
        </MudText>

        @if (_diag is not null)
        {
            <MudPaper Class="pa-3 mb-3" Elevation="0" Style="background: var(--coffee-surface-soft);">
                <MudText Typo="Typo.caption" Class="d-block">
                    <strong>@Loc.T("settings.diagnostic_visits")</strong> @_diag.VisitCount ·
                    <strong>@Loc.T("settings.diagnostic_shops")</strong> @_diag.ShopCount ·
                    <strong>@Loc.T("settings.diagnostic_pending")</strong> @_diag.PendingVisitCount
                    @if (_diag.OrphanVisitCount > 0)
                    {
                        <span> · <strong>@Loc.T("settings.diagnostic_orphans")</strong> @_diag.OrphanVisitCount</span>
                    }
                </MudText>
                @if (_diag.PendingPreview.Count > 0)
                {
                    <MudText Typo="Typo.caption" Class="mud-text-secondary mt-2 d-block">
                        @Loc.T("settings.diagnostic_pending_preview")
                        @foreach (var p in _diag.PendingPreview)
                        {
                            <span class="d-block ml-2">• @p</span>
                        }
                    </MudText>
                }
            </MudPaper>
        }

        <div class="d-flex flex-wrap" style="gap:8px;">
            <MudButton Variant="Variant.Outlined" Color="Color.Default"
                       StartIcon="@Icons.Material.Filled.Search"
                       OnClick="DiagnoseAsync" Disabled="_busy">
                @Loc.T("settings.btn_diagnose")
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Build"
                       OnClick="RebuildShopsAsync" Disabled="_busy">
                @Loc.T("settings.btn_rebuild")
            </MudButton>
        </div>

        @if (!string.IsNullOrEmpty(_migrationStatus))
        {
            <MudText Typo="Typo.caption" Class="mt-2 d-block" Style="white-space:pre-wrap;">@_migrationStatus</MudText>
        }
    </MudPaper>

    <MudPaper Class="pa-4" Elevation="0">
        <MudText Typo="Typo.h6" Class="mb-1">@Loc.T("settings.section_danger")</MudText>
        <MudText Typo="Typo.body2" Class="mud-text-secondary mb-3">
            @Loc.T("settings.danger_help")
        </MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Error"
                   StartIcon="@Icons.Material.Filled.DeleteForever"
                   OnClick="EraseAllAsync" Disabled="_busy">
            @Loc.T("settings.btn_erase")
        </MudButton>
    </MudPaper>

</MudStack>

@code {
    private bool _busy;
    private string? _googleKey;
    private string? _pat;
    private bool _notifSupported;
    private bool _notifEnabled;
    private string _notifPermission = "default";
    private MigrationDiagnostic? _diag;
    private string? _migrationStatus;
    /// <summary>"auto" si pas de préférence explicite, sinon le code langue ("fr"/"en"/"it").</summary>
    private string _langValue = "auto";

    protected override async Task OnInitializedAsync()
    {
        _googleKey = await PlaceSearch.GetGoogleKeyAsync();
        _pat = Sync.Pat;
        Sync.StateChanged += OnSyncChanged;

        _langValue = Loc.HasUserPreference ? Loc.CurrentLanguage : "auto";

        _notifSupported = await Alerts.IsSupportedAsync();
        if (_notifSupported)
        {
            _notifEnabled = await Alerts.IsEnabledAsync();
            _notifPermission = await Alerts.GetPermissionAsync();
        }
    }

    private async Task OnToggleNotifsAsync(bool enabled)
    {
        if (enabled)
        {
            // Demande la permission au navigateur si pas encore accordée
            var granted = await Alerts.RequestPermissionAsync();
            _notifPermission = await Alerts.GetPermissionAsync();
            if (!granted)
            {
                Snackbar.Add(Loc.T("settings.snack_notifs_denied"), Severity.Warning);
                _notifEnabled = false;
                return;
            }
        }
        await Alerts.SetEnabledAsync(enabled);
        _notifEnabled = enabled;
        Snackbar.Add(enabled ? Loc.T("settings.snack_notifs_on") : Loc.T("settings.snack_notifs_off"), Severity.Success);
    }

    private void OnSyncChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => Sync.StateChanged -= OnSyncChanged;

    private async Task SavePatAsync()
    {
        await Sync.SetPatAsync(_pat);
        Snackbar.Add(string.IsNullOrWhiteSpace(_pat) ? Loc.T("settings.snack_token_cleared") : Loc.T("settings.snack_token_saved"), Severity.Success);
    }

    private async Task SyncNowAsync()
    {
        var ok = await Sync.SyncAsync();
        if (ok) Snackbar.Add(Loc.T("settings.snack_sync_ok"), Severity.Success);
        else if (!string.IsNullOrEmpty(Sync.LastError)) Snackbar.Add(Sync.LastError, Severity.Error);
    }

    private async Task DisconnectSyncAsync()
    {
        var ok = await Dialogs.ShowMessageBoxAsync(new MessageBoxOptions
        {
            Title = Loc.T("settings.sync_disconnect_title"),
            Message = Loc.T("settings.sync_disconnect_msg"),
            YesText = Loc.T("settings.sync_btn_disconnect_yes"),
            CancelText = Loc.T("common.cancel")
        });
        if (ok != true) return;
        await Sync.DisconnectAsync();
        _pat = null;
        Snackbar.Add(Loc.T("settings.snack_sync_disconnected"), Severity.Info);
    }

    private async Task SaveGoogleKeyAsync()
    {
        _busy = true;
        try
        {
            await PlaceSearch.SetGoogleKeyAsync(_googleKey);
            Snackbar.Add(string.IsNullOrWhiteSpace(_googleKey) ? Loc.T("settings.snack_key_cleared") : Loc.T("settings.snack_key_saved"), Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(Loc.T("common.error_prefix", ex.Message), Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task ClearGoogleKeyAsync()
    {
        _googleKey = null;
        await PlaceSearch.SetGoogleKeyAsync(null);
        Snackbar.Add(Loc.T("settings.snack_key_cleared"), Severity.Info);
    }

    private async Task OnThemeChanged(string pref)
    {
        await Theme.SetPreferenceAsync(pref);
    }

    private async Task OnLanguageChangedAsync(string val)
    {
        _langValue = val;
        if (val == "auto")
            await Loc.ResetToBrowserAsync();
        else
            await Loc.SetLanguageAsync(val);
    }

    private static readonly JsonSerializerOptions ExportOptions = new()
    {
        WriteIndented = true,
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
        DictionaryKeyPolicy = JsonNamingPolicy.CamelCase,
        Converters = { new JsonStringEnumConverter(JsonNamingPolicy.CamelCase) },
        DefaultIgnoreCondition = JsonIgnoreCondition.WhenWritingNull
    };

    private static readonly JsonSerializerOptions ImportOptions = new()
    {
        PropertyNameCaseInsensitive = true,
        Converters = { new JsonStringEnumConverter(JsonNamingPolicy.CamelCase) }
    };

    private async Task ExportAsync()
    {
        _busy = true;
        try
        {
            var coffees = await Db.Coffees.ToCollection().ToList();
            var brews = await Db.Brews.ToCollection().ToList();
            var visits = await Db.ShopVisits.ToCollection().ToList();
            var shops = await Db.Shops.ToCollection().ToList();
            var machines = await Db.Machines.ToCollection().ToList();

            var data = new ExportFile
            {
                Version = 4,
                ExportedAt = DateTime.UtcNow,
                Coffees = coffees,
                Brews = brews,
                Shops = shops,
                ShopVisits = visits,
                Machines = machines
            };

            var json = JsonSerializer.Serialize(data, ExportOptions);
            var filename = $"coffee-tracker-{DateTime.Now:yyyy-MM-dd}.json";
            await JS.InvokeVoidAsync("coffeeData.downloadJson", filename, json);

            var summary = Loc.T("settings.import_summary", coffees.Count, brews.Count, shops.Count, visits.Count, machines.Count);
            Snackbar.Add(Loc.T("settings.snack_export_ok", summary), Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(Loc.T("settings.snack_export_error", ex.Message), Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task OnImportFileSelectedAsync(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;

        string json;
        try
        {
            await using var stream = file.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024);
            using var reader = new StreamReader(stream);
            json = await reader.ReadToEndAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(Loc.T("settings.snack_import_read_error", ex.Message), Severity.Error);
            return;
        }

        ExportFile? parsed;
        try
        {
            parsed = JsonSerializer.Deserialize<ExportFile>(json, ImportOptions);
        }
        catch (Exception ex)
        {
            Snackbar.Add(Loc.T("settings.snack_import_invalid", ex.Message), Severity.Error);
            return;
        }

        if (parsed is null)
        {
            Snackbar.Add(Loc.T("settings.snack_import_empty"), Severity.Error);
            return;
        }

        var summary = Loc.T("settings.import_summary",
            parsed.Coffees?.Count ?? 0, parsed.Brews?.Count ?? 0, parsed.Shops?.Count ?? 0,
            parsed.ShopVisits?.Count ?? 0, parsed.Machines?.Count ?? 0);
        var ok = await Dialogs.ShowMessageBoxAsync(new MessageBoxOptions
        {
            Title = Loc.T("settings.import_title"),
            Message = Loc.T("settings.import_msg", summary),
            YesText = Loc.T("settings.import_yes"),
            CancelText = Loc.T("common.cancel")
        });
        if (ok != true) return;

        _busy = true;
        try
        {
            await Db.Coffees.Clear();
            await Db.Brews.Clear();
            await Db.ShopVisits.Clear();
            await Db.Shops.Clear();
            await Db.Machines.Clear();

            foreach (var c in parsed.Coffees ?? new()) await Db.Coffees.Put(c);
            foreach (var b in parsed.Brews ?? new()) await Db.Brews.Put(b);
            foreach (var s in parsed.Shops ?? new()) await Db.Shops.Put(s);
            foreach (var v in parsed.ShopVisits ?? new()) await Db.ShopVisits.Put(v);
            foreach (var m in parsed.Machines ?? new()) await Db.Machines.Put(m);

            // Pour un fichier v ≤ 3 (sans Shops), la migration tournera au prochain reload
            // pour reconstruire les Shops à partir des visites.
            Snackbar.Add(Loc.T("settings.snack_import_ok", summary), Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(Loc.T("settings.snack_import_error", ex.Message), Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task DiagnoseAsync()
    {
        _busy = true;
        _migrationStatus = null;
        try
        {
            _diag = await Migrations.DiagnoseAsync();
        }
        catch (Exception ex)
        {
            _migrationStatus = $"{Loc.T("settings.diagnostic_error", ex.Message)}\n{ex.GetType().Name}";
            Snackbar.Add(Loc.T("settings.diagnostic_failed_diag_snack"), Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task RebuildShopsAsync()
    {
        _busy = true;
        _migrationStatus = null;
        try
        {
            var report = await Migrations.RunManualAsync();
            _diag = await Migrations.DiagnoseAsync();
            if (report.HasChanges)
            {
                _migrationStatus = Loc.T("settings.diagnostic_success", report.ShopsCreated, report.VisitsLinked);
                Snackbar.Add(_migrationStatus, Severity.Success);
            }
            else
            {
                _migrationStatus = Loc.T("settings.diagnostic_nothing");
                Snackbar.Add(_migrationStatus, Severity.Info);
            }
        }
        catch (Exception ex)
        {
            _migrationStatus = $"{Loc.T("settings.diagnostic_migration_error", ex.Message)}\n{ex.GetType().Name}\n{ex.StackTrace}";
            Snackbar.Add(Loc.T("settings.diagnostic_failed_snack"), Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task EraseAllAsync()
    {
        var ok = await Dialogs.ShowMessageBoxAsync(new MessageBoxOptions
        {
            Title = Loc.T("settings.erase_title"),
            Message = Loc.T("settings.erase_msg"),
            YesText = Loc.T("settings.btn_erase"),
            CancelText = Loc.T("common.cancel")
        });
        if (ok != true) return;

        _busy = true;
        try
        {
            await Db.Coffees.Clear();
            await Db.Brews.Clear();
            await Db.ShopVisits.Clear();
            await Db.Shops.Clear();
            await Db.Machines.Clear();
            Snackbar.Add(Loc.T("settings.snack_erased"), Severity.Info);
        }
        catch (Exception ex)
        {
            Snackbar.Add(Loc.T("common.error_prefix", ex.Message), Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private class ExportFile
    {
        public int Version { get; set; } = 4;
        public DateTime ExportedAt { get; set; }
        public List<Coffee>? Coffees { get; set; }
        public List<Brew>? Brews { get; set; }
        public List<Shop>? Shops { get; set; }
        public List<CoffeeShopVisit>? ShopVisits { get; set; }
        public List<Machine>? Machines { get; set; }
    }
}
