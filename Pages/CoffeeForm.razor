@*
    CRUD café. Trois modes selon les flags :
    - IsOwned = true  → sac avec poids/prix/dates (achats trackés, stock calculé)
    - IsOwned = false → café simplement dégusté (champs achats masqués)
    - IsBlend = true  → masque les champs origine et affiche un champ Composition libre
    Un sélecteur DecafProcess apparaît conditionnellement quand IsDecaf est coché.
*@
@page "/coffees/new"
@page "/coffees/{Id:int}/edit"
@implements IDisposable
@inject CoffeeDb Db
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@inject SyncService Sync
@inject LocalizationService Loc

<PageTitle>@(IsEdit ? Loc.T("coffeeform.title_edit") : Loc.T("coffeeform.title_new"))</PageTitle>

<PageHeader Title="@(IsEdit ? Loc.T("coffeeform.title_edit") : Loc.T("coffeeform.title_new"))" Back="true" BackUrl="@(IsEdit ? $"coffees/{Id}" : "coffees")" />

<EditForm Model="_model" OnValidSubmit="SaveAsync">
    <DataAnnotationsValidator />

    <MudStack Spacing="4">

        <MudPaper Class="pa-4" Elevation="0">
            <MudSwitch T="bool" @bind-Value="_model.IsOwned" Color="Color.Primary"
                       Label="@(_model.IsOwned ? Loc.T("coffeeform.field_owned") : Loc.T("coffeeform.field_tasted"))" />
        </MudPaper>

        <MudPaper Class="pa-4" Elevation="0">
            <MudText Typo="Typo.overline" Class="mud-text-secondary mb-2">@Loc.T("coffeeform.section_photo")</MudText>
            <div class="d-flex align-center" style="gap:12px;">
                @if (!string.IsNullOrEmpty(_model.PhotoDataUrl))
                {
                    <img src="@_model.PhotoDataUrl" class="photo-preview" alt="" />
                }
                else
                {
                    <div class="photo-preview placeholder">
                        <MudIcon Icon="@Icons.Material.Filled.PhotoCamera" />
                    </div>
                }
                <MudStack Spacing="1">
                    <InputFile id="coffeePhotoInput" OnChange="OnPhotoSelectedAsync" accept="image/*" capture="environment" style="display:none;" />
                    <label for="coffeePhotoInput" class="upload-button">
                        <MudIcon Icon="@Icons.Material.Filled.PhotoCamera" Size="Size.Small" />
                        <span>@(string.IsNullOrEmpty(_model.PhotoDataUrl) ? Loc.T("coffeeform.photo_add") : Loc.T("coffeeform.photo_change"))</span>
                    </label>
                    @if (!string.IsNullOrEmpty(_model.PhotoDataUrl))
                    {
                        <MudButton Variant="Variant.Text" Color="Color.Default" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Close"
                                   OnClick="@(() => _model.PhotoDataUrl = null)">@Loc.T("coffeeform.photo_remove")</MudButton>
                    }
                </MudStack>
            </div>
        </MudPaper>

        <MudPaper Class="pa-4" Elevation="0">
            <MudTextField @bind-Value="_model.Roaster"
                          Label="@(_model.IsOwned ? Loc.T("coffeeform.field_roaster") : Loc.T("coffeeform.field_roaster").Replace(" *", ""))"
                          Variant="Variant.Outlined" Required="@_model.IsOwned"
                          Class="mb-3" />
            <MudTextField @bind-Value="_model.Name" Label="@Loc.T("coffeeform.field_name")" Variant="Variant.Outlined" Required="true" />
        </MudPaper>

        @if (_model.IsBlend)
        {
            <MudPaper Class="pa-4" Elevation="0">
                <MudText Typo="Typo.overline" Class="mud-text-secondary mb-2">@Loc.T("coffeeform.field_composition")</MudText>
                <MudTextField @bind-Value="_model.Composition" Label="@Loc.T("coffeeform.field_composition")"
                              Variant="Variant.Outlined" Lines="4"
                              Placeholder="@Loc.T("coffeeform.field_composition_placeholder")" />
            </MudPaper>
        }
        else
        {
            <MudPaper Class="pa-4" Elevation="0">
                <MudText Typo="Typo.overline" Class="mud-text-secondary mb-2">@Loc.T("coffeeform.section_origin")</MudText>
                <MudGrid Spacing="2">
                    <MudItem xs="6"><MudTextField @bind-Value="_model.Country" Label="@Loc.T("coffeeform.field_country")" Variant="Variant.Outlined" /></MudItem>
                    <MudItem xs="6"><MudTextField @bind-Value="_model.Region" Label="@Loc.T("coffeeform.field_region")" Variant="Variant.Outlined" /></MudItem>
                    <MudItem xs="12"><MudTextField @bind-Value="_model.Farm" Label="@Loc.T("coffeeform.field_farm")" Variant="Variant.Outlined" /></MudItem>
                    <MudItem xs="6"><MudTextField @bind-Value="_model.Producer" Label="@Loc.T("coffeeform.field_producer")" Variant="Variant.Outlined" /></MudItem>
                    <MudItem xs="6"><MudTextField @bind-Value="_model.Altitude" Label="@Loc.T("coffeeform.field_altitude")" Variant="Variant.Outlined" Placeholder="1800-2000m" /></MudItem>
                    <MudItem xs="12"><MudTextField @bind-Value="_model.Variety" Label="@Loc.T("coffeeform.field_variety")" Variant="Variant.Outlined" Placeholder="Geisha, Bourbon…" /></MudItem>
                </MudGrid>
            </MudPaper>
        }

        <MudPaper Class="pa-4" Elevation="0">
            <MudText Typo="Typo.overline" Class="mud-text-secondary mb-2">@Loc.T("coffeeform.section_roast")</MudText>
            <MudSelect T="Process" @bind-Value="_model.Process" Label="@Loc.T("coffeeform.field_process")" Variant="Variant.Outlined" Class="mb-3">
                @foreach (var p in Enum.GetValues<Process>())
                {
                    <MudSelectItem T="Process" Value="@p">@p.GetLabel()</MudSelectItem>
                }
            </MudSelect>
            <MudTextField @bind-Value="_model.ProcessNotes" Label="@Loc.T("coffeeform.field_process_notes")" Variant="Variant.Outlined" Class="mb-3" />
            <MudSwitch T="bool" @bind-Value="_model.IsDecaf" Label="@Loc.T("coffeeform.field_decaf")" Color="Color.Primary" Class="mb-2" />
            @if (_model.IsDecaf)
            {
                <MudSelect T="DecafProcess?" @bind-Value="_model.DecafMethod"
                           Label="@Loc.T("coffeeform.field_decaf_method")"
                           Variant="Variant.Outlined" Clearable="true" Class="mb-3">
                    @foreach (var d in Enum.GetValues<DecafProcess>())
                    {
                        <MudSelectItem T="DecafProcess?" Value="@d">@d.GetLabel()</MudSelectItem>
                    }
                </MudSelect>
            }
            <MudSwitch T="bool" @bind-Value="_model.IsBlend" Label="@Loc.T("coffeeform.field_blend")" Color="Color.Primary" Class="mb-3" />
            <MudGrid Spacing="2">
                <MudItem xs="6">
                    <MudSelect T="RoastLevel?" @bind-Value="_model.RoastLevel" Label="@Loc.T("coffeeform.field_roast_level")" Variant="Variant.Outlined" Clearable="true">
                        @foreach (var r in Enum.GetValues<RoastLevel>())
                        {
                            <MudSelectItem T="RoastLevel?" Value="@r">@r.GetLabel()</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="6">
                    <MudDatePicker @bind-Date="_roastDate" Label="@Loc.T("coffeeform.field_roast_date")" Variant="Variant.Outlined" Editable="true" />
                </MudItem>
            </MudGrid>
        </MudPaper>

        @if (_model.IsOwned)
        {
            <MudPaper Class="pa-4" Elevation="0">
                <MudText Typo="Typo.overline" Class="mud-text-secondary mb-2">@Loc.T("coffeeform.section_purchase")</MudText>
                <MudGrid Spacing="2">
                    <MudItem xs="6">
                        <MudDatePicker @bind-Date="_purchaseDate" Label="@Loc.T("coffeeform.field_purchase_date")" Variant="Variant.Outlined" Required="true" Editable="true" />
                    </MudItem>
                    <MudItem xs="6">
                        <MudNumericField T="int?" @bind-Value="_model.WeightGrams" Label="@Loc.T("coffeeform.field_weight")" Variant="Variant.Outlined" Min="0" Placeholder="250" />
                    </MudItem>
                    <MudItem xs="8">
                        <MudNumericField T="decimal?" @bind-Value="_model.Price" Label="@Loc.T("coffeeform.field_price")" Variant="Variant.Outlined" Format="0.##" Culture="@_inv" />
                    </MudItem>
                    <MudItem xs="4">
                        <MudTextField @bind-Value="_model.Currency" Label="@Loc.T("coffeeform.field_currency")" Variant="Variant.Outlined" />
                    </MudItem>
                </MudGrid>
            </MudPaper>
        }

        <MudPaper Class="pa-4" Elevation="0">
            <MudText Typo="Typo.overline" Class="mud-text-secondary mb-2">@Loc.T("coffeeform.section_notes")</MudText>
            <MudTextField @bind-Value="_model.TastingNotes" Label="@Loc.T("coffeeform.field_tasting_notes")" Variant="Variant.Outlined"
                          Lines="4" Placeholder="@Loc.T("coffeeform.field_tasting_placeholder")" />
        </MudPaper>

        <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Size="Size.Large"
                   StartIcon="@Icons.Material.Filled.Save" Disabled="_saving">
            @(IsEdit ? Loc.T("common.save") : Loc.T("coffeeform.btn_create"))
        </MudButton>

    </MudStack>
</EditForm>

<style>
    .photo-preview {
        width: 80px; height: 80px; border-radius: 12px; object-fit: cover;
    }
    .photo-preview.placeholder {
        background: var(--coffee-surface-soft); display: flex; align-items: center; justify-content: center; color: var(--coffee-accent-soft);
    }
</style>

@code {
    [Parameter] public int? Id { get; set; }
    private bool IsEdit => Id is not null;

    private Coffee _model = new();
    private DateTime? _purchaseDate = DateTime.Today;
    private DateTime? _roastDate;
    private bool _saving;
    private readonly System.Globalization.CultureInfo _inv = System.Globalization.CultureInfo.InvariantCulture;

    protected override void OnInitialized() => Loc.LanguageChanged += OnLangChanged;
    private void OnLangChanged() => InvokeAsync(StateHasChanged);
    public void Dispose() => Loc.LanguageChanged -= OnLangChanged;

    protected override async Task OnParametersSetAsync()
    {
        if (IsEdit)
        {
            var c = await Db.Coffees.Get(Id!.Value);
            if (c is not null)
            {
                _model = c;
                _purchaseDate = c.PurchaseDate.ToDateTime(TimeOnly.MinValue);
                _roastDate = c.RoastDate?.ToDateTime(TimeOnly.MinValue);
            }
        }
    }

    private async Task OnPhotoSelectedAsync(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;
        try
        {
            var maxBytes = 10 * 1024 * 1024;
            await using var stream = file.OpenReadStream(maxBytes);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            var bytes = ms.ToArray();
            var dataUrl = await JS.InvokeAsync<string>("coffeeImage.bytesToCompressedDataUrl",
                bytes, file.ContentType, 1024, 0.82);
            _model.PhotoDataUrl = dataUrl;
        }
        catch (Exception ex)
        {
            Snackbar.Add(Loc.T("coffeeform.photo_error", ex.Message), Severity.Error);
        }
    }

    private async Task SaveAsync()
    {
        _saving = true;
        try
        {
            _model.PurchaseDate = DateOnly.FromDateTime(_purchaseDate ?? DateTime.Today);
            _model.RoastDate = _roastDate is null ? null : DateOnly.FromDateTime(_roastDate.Value);
            _model.UpdatedAt = DateTime.UtcNow;

            if (IsEdit)
            {
                _model.Id = Id!.Value;
                await Db.Coffees.Put(_model);
                Sync.RequestPush();
                Snackbar.Add(Loc.T("coffeeform.snack_saved"), Severity.Success);
                Nav.NavigateTo($"coffees/{Id}");
            }
            else
            {
                _model.CreatedAt = DateTime.UtcNow;
                _model.Id = 0;
                var newId = await Db.Coffees.Add(_model);
                Sync.RequestPush();
                Snackbar.Add(Loc.T("coffeeform.snack_created"), Severity.Success);
                Nav.NavigateTo($"coffees/{newId}");
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(Loc.T("common.error_prefix", ex.Message), Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }
}
