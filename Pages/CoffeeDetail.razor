@*
    Fiche détaillée d'un café. Affiche origine/process/dégazage/stock/brews liés.
    Trois actions principales :
    - Bouton « Ajuster le stock » → ouvre StockAdjustmentDialog (cf. Coffee.StockAdjustmentG)
    - Bouton « Marquer terminé » / « Rouvrir » → toggle FinishedAt
    - Sélection 2 brews + bouton Comparer → BrewCompareDialog
    La liste de brews permet aussi un « Refaire ce brew » qui navigue vers /brews/new?fromBrewId=X.
*@
@page "/coffees/{Id:int}"
@implements IDisposable
@inject CoffeeDb Db
@inject NavigationManager Nav
@inject IDialogService Dialogs
@inject ISnackbar Snackbar
@inject SyncService Sync
@inject LocalizationService Loc

<PageTitle>@(_coffee?.Name ?? Loc.T("nav.coffees"))</PageTitle>

<PageHeader Title="@(_coffee?.Name ?? Loc.T("nav.coffees"))"
            Subtitle="@(_coffee?.Roaster ?? string.Empty)"
            Back="true" BackUrl="coffees">
    <Action>
        @if (_coffee is not null)
        {
            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Medium"
                           OnClick="@(() => Nav.NavigateTo($"coffees/{Id}/edit"))" />
        }
    </Action>
</PageHeader>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-4" />
}
else if (_coffee is null)
{
    <MudText Class="pa-4">@Loc.T("coffeedetail.not_found")</MudText>
}
else
{
    <MudStack Spacing="3">
        @if (!string.IsNullOrEmpty(_coffee.PhotoDataUrl))
        {
            <img src="@_coffee.PhotoDataUrl" alt="" class="hero-photo" />
        }

        <MudPaper Class="pa-4" Elevation="0">
            @if (_coffee.IsBlend)
            {
                <DetailRow Label="@Loc.T("coffeedetail.label_type")" Value="@Loc.T("coffeedetail.value_blend")" />
                @if (!string.IsNullOrEmpty(_coffee.Composition))
                {
                    <DetailRow Label="@Loc.T("coffeedetail.label_composition")" Value="@_coffee.Composition" />
                }
            }
            else
            {
                <DetailRow Label="@Loc.T("coffeedetail.label_origin")" Value="@OriginLine()" />
                @if (!string.IsNullOrEmpty(_coffee.Producer))
                {
                    <DetailRow Label="@Loc.T("coffeedetail.label_producer")" Value="@_coffee.Producer" />
                }
                @if (!string.IsNullOrEmpty(_coffee.Altitude))
                {
                    <DetailRow Label="@Loc.T("coffeedetail.label_altitude")" Value="@_coffee.Altitude" />
                }
                @if (!string.IsNullOrEmpty(_coffee.Variety))
                {
                    <DetailRow Label="@Loc.T("coffeedetail.label_variety")" Value="@_coffee.Variety" />
                }
            }
            <DetailRow Label="@Loc.T("coffeedetail.label_process")" Value="@_coffee.Process.GetLabel()" />
            @if (!string.IsNullOrEmpty(_coffee.ProcessNotes))
            {
                <DetailRow Label="@Loc.T("coffeedetail.label_process_notes")" Value="@_coffee.ProcessNotes" />
            }
            <DetailRow Label="@Loc.T("coffeedetail.label_caffeine")" Value="@(_coffee.IsDecaf ? Loc.T("coffeedetail.value_decaf") : Loc.T("coffeedetail.value_normal"))" />
            @if (_coffee.IsDecaf && _coffee.DecafMethod is not null)
            {
                <DetailRow Label="@Loc.T("coffeedetail.label_decaf_method")" Value="@_coffee.DecafMethod.Value.GetLabel()" />
            }
            @if (_coffee.RoastLevel is not null)
            {
                <DetailRow Label="@Loc.T("coffeedetail.label_roast_level")" Value="@_coffee.RoastLevel.Value.GetLabel()" />
            }
            @if (_coffee.RoastDate is not null)
            {
                var days = Format.DaysSince(_coffee.RoastDate);
                <DetailRow Label="@Loc.T("coffeedetail.label_roast_date")"
                           Value="@($"{Format.Date(_coffee.RoastDate)}{(days is null ? "" : $" · {Loc.T("coffeedetail.days_ago", days)}")}")" />
            }
        </MudPaper>

        <MudPaper Class="pa-4" Elevation="0">
            <DetailRow Label="@Loc.T("coffeedetail.label_owned")" Value="@(_coffee.IsOwned ? Loc.T("coffeedetail.value_owned") : Loc.T("coffeedetail.value_tasted"))" />
            @if (_coffee.IsOwned)
            {
                <DetailRow Label="@Loc.T("coffeedetail.label_purchase")" Value="@Format.Date(_coffee.PurchaseDate)" />
                @if (_coffee.WeightGrams is not null)
                {
                    <DetailRow Label="@Loc.T("coffeedetail.label_weight")" Value="@($"{_coffee.WeightGrams} g")" />
                }
                @if (_coffee.Price is not null)
                {
                    <DetailRow Label="@Loc.T("coffeedetail.label_price")" Value="@Format.Price(_coffee.Price, _coffee.Currency)" />
                }
                @if (CostPerGram is decimal cpgVal)
                {
                    <DetailRow Label="@Loc.T("coffeedetail.label_cost_per_g")" Value="@($"{cpgVal.ToString("0.000", System.Globalization.CultureInfo.InvariantCulture)} {_coffee.Currency}/g")" />
                }
                @if (AvgCostPerCup is decimal accVal)
                {
                    <DetailRow Label="@Loc.T("coffeedetail.label_avg_cost_per_cup")" Value="@Format.Price(accVal, _coffee.Currency)" />
                }
                <DetailRow Label="@Loc.T("coffeedetail.label_status")"
                           Value="@(_coffee.FinishedAt is null ? Loc.T("coffeedetail.value_active") : Loc.T("coffeedetail.value_finished", Format.DateTimeShort(_coffee.FinishedAt)))" />
            }
        </MudPaper>

        @{ var deg = Degassing.Compute(_coffee.RoastDate); }
        @if (deg is not null && _coffee.FinishedAt is null)
        {
            var pct = Math.Min(100.0, deg.Days * 100.0 / Degassing.MaxDays);
            <MudPaper Class="pa-4" Elevation="0">
                <div class="d-flex align-baseline justify-space-between mb-2">
                    <MudText Typo="Typo.overline" Class="mud-text-secondary">@Loc.T("coffeedetail.section_degassing")</MudText>
                    <MudText Style="font-weight:600;">
                        @deg.Days @Loc.T("common.day_short")
                        <span class="mud-text-secondary" style="font-weight:400; font-size:13px;"> · @Loc.T($"degas.{ZoneToKey(deg.Zone)}_short")</span>
                    </MudText>
                </div>
                <div class="degas-track">
                    <div class="degas-zone z-fresh"></div>
                    <div class="degas-zone z-filter"></div>
                    <div class="degas-zone z-optimal"></div>
                    <div class="degas-zone z-decline"></div>
                    <div class="degas-zone z-past"></div>
                    <div class="degas-marker" style="@($"left: {pct.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture)}%;")"></div>
                </div>
                <div class="degas-legend">
                    <span>0@Loc.T("common.day_short")</span>
                    <span>7@Loc.T("common.day_short")</span>
                    <span>21@Loc.T("common.day_short")</span>
                    <span>35@Loc.T("common.day_short")</span>
                    <span>42@Loc.T("common.day_short")+</span>
                </div>
                <MudText Typo="Typo.caption" Class="mud-text-secondary mt-2 d-block">@Loc.T($"degas.{ZoneToKey(deg.Zone)}_long")</MudText>
            </MudPaper>
        }

        @if (_coffee.WeightGrams is int totalGrams && _coffee.FinishedAt is null)
        {
            var used = _brews.Sum(b => b.DoseG ?? 0m);
            var adjusted = totalGrams + _coffee.StockAdjustmentG;
            var remaining = adjusted - used;
            var pct = adjusted > 0m ? (double)Math.Max(0m, remaining) / (double)adjusted * 100 : 0;
            var color = remaining <= 30m ? Color.Error : (remaining <= 60m ? Color.Warning : Color.Primary);
            <MudPaper Class="pa-4" Elevation="0">
                <div class="d-flex justify-space-between align-baseline mb-2">
                    <MudText Typo="Typo.overline" Class="mud-text-secondary">@Loc.T("coffeedetail.section_stock")</MudText>
                    <MudText Style="font-weight:600;">
                        @Loc.T("coffeedetail.stock_unit", remaining.ToString("0.#"))
                        <span class="mud-text-secondary" style="font-weight:400; font-size:13px;"> @Loc.T("coffeedetail.stock_of_total", totalGrams)</span>
                    </MudText>
                </div>
                <MudProgressLinear Value="@pct" Color="@color" Style="height:8px; border-radius:4px;" />
                @if (_coffee.StockAdjustmentG != 0m)
                {
                    var sign = _coffee.StockAdjustmentG > 0m ? "+" : "";
                    <MudText Typo="Typo.caption" Class="mud-text-secondary mt-2 d-block">
                        @Loc.T("coffeedetail.stock_adjustment_includes", $"{sign}{_coffee.StockAdjustmentG.ToString("0.#")}")
                    </MudText>
                }
                @if (remaining <= 0m)
                {
                    <MudText Typo="Typo.caption" Color="Color.Error" Class="mt-2">@Loc.T("coffeedetail.stock_empty")</MudText>
                }
                else if (remaining <= 30m)
                {
                    <MudText Typo="Typo.caption" Color="Color.Error" Class="mt-2">@Loc.T("coffeedetail.stock_low")</MudText>
                }
                <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Tune"
                           OnClick="OpenStockAdjustAsync"
                           Class="mt-2">@Loc.T("coffeedetail.stock_adjust_btn")</MudButton>
            </MudPaper>
        }

        @if (!string.IsNullOrEmpty(_coffee.TastingNotes))
        {
            <MudPaper Class="pa-4" Elevation="0">
                <MudText Typo="Typo.overline" Class="mud-text-secondary">@Loc.T("coffeedetail.section_roaster_notes")</MudText>
                <MudText Class="mt-1" Style="white-space: pre-wrap;">@_coffee.TastingNotes</MudText>
            </MudPaper>
        }

        @if (_coffee.IsOwned)
        {
        <MudPaper Class="pa-4" Elevation="0">
            <div class="d-flex align-center justify-space-between mb-3">
                <MudText Typo="Typo.h6">@Loc.T("coffeedetail.section_brews", _brews.Count)</MudText>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add"
                           Size="Size.Small"
                           OnClick="@(() => Nav.NavigateTo($"brews/new?coffeeId={Id}"))">@Loc.T("common.add")</MudButton>
            </div>
            @if (_brews.Count > 0)
            {
                <div class="d-flex align-center mb-3" style="gap:8px;">
                    <span class="mud-text-secondary" style="font-size:14px;">@Loc.T("coffeedetail.brews_average")</span>
                    <StarRating Value="@((int)Math.Round(_brews.Average(b => b.Rating)))" ReadOnly="true" Size="Size.Small" />
                    <span class="mud-text-secondary" style="font-size:14px;">(@_brews.Average(b => b.Rating).ToString("0.0"))</span>
                </div>
            }
            @if (_chartSeries is not null)
            {
                <div class="mb-3">
                    <MudText Typo="Typo.caption" Class="mud-text-secondary mb-1 d-block">@Loc.T("coffeedetail.brews_chart_title")</MudText>
                    <MudChart T="double"
                              ChartType="ChartType.Line"
                              ChartSeries="@_chartSeries"
                              ChartLabels="@_chartLabels"
                              ChartOptions="@_chartOptions"
                              Width="100%" Height="160px" />
                </div>
            }
            @if (_brews.Count == 0)
            {
                <MudText Class="mud-text-secondary">@Loc.T("coffeedetail.brews_empty")</MudText>
            }
            else
            {
                <MudList T="Brew" Class="pa-0">
                    @foreach (var b in _brews)
                    {
                        <MudListItem T="Brew" OnClick="@(() => Nav.NavigateTo($"brews/{b.Id}/edit"))" Class="px-2">
                            <div class="d-flex align-center" style="gap:8px;">
                                <span @onclick="() => ToggleSelected(b.Id)" @onclick:stopPropagation="true" @onclick:preventDefault="true">
                                    <MudCheckBox T="bool"
                                                 Value="@_selectedBrewIds.Contains(b.Id)"
                                                 ValueChanged="@((bool _) => ToggleSelected(b.Id))"
                                                 Color="Color.Primary" Size="Size.Small" Dense="true" />
                                </span>
                                <div class="thumb-sm thumb-placeholder">
                                    <MudIcon Icon="@Icons.Material.Filled.LocalCafe" Size="Size.Small" />
                                </div>
                                <div style="flex:1; min-width:0;">
                                    <div class="d-flex align-center justify-space-between">
                                        <div class="d-flex align-center" style="gap:6px;">
                                            <MudText Style="font-weight:500;">@b.Method.GetLabel()</MudText>
                                            @if (b.IsFavorite)
                                            {
                                                <MudIcon Icon="@Icons.Material.Filled.Favorite" Size="Size.Small" Style="color:#dc2626;" />
                                            }
                                        </div>
                                        <StarRating Value="@b.Rating" ReadOnly="true" Size="Size.Small" />
                                    </div>
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                        @Format.DateTimeShort(b.Date)
                                        @{ var ratio = string.IsNullOrEmpty(b.Ratio) ? Format.Ratio(b.DoseG, b.YieldG) : b.Ratio; }
                                        @if (!string.IsNullOrEmpty(ratio)) { <span> · @ratio</span> }
                                        @if (b.DoseG is not null) { <span> · @b.DoseG g</span> }
                                        @if (b.Milk is MilkType milk) { <span> · 🥛 @milk.GetLabel()</span> }
                                    </MudText>
                                </div>
                                <span @onclick:stopPropagation="true">
                                    <MudIconButton Icon="@Icons.Material.Filled.Replay" Size="Size.Small"
                                                   Color="Color.Primary"
                                                   OnClick="@(() => GoDuplicate(b.Id))"
                                                   aria-label="@Loc.T("coffeedetail.brew_redo_aria")" />
                                </span>
                            </div>
                        </MudListItem>
                    }
                </MudList>
                @if (_brews.Count >= 2)
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                               StartIcon="@Icons.Material.Filled.Compare"
                               Disabled="@(_selectedBrewIds.Count != 2)"
                               OnClick="OpenCompareAsync"
                               Class="mt-3">
                        @Loc.T("coffeedetail.compare_btn", _selectedBrewIds.Count)
                    </MudButton>
                }
            }
        </MudPaper>
        }

        <MudGrid Spacing="2">
            @if (_coffee.IsOwned)
            {
                <MudItem xs="6">
                    <MudButton Variant="Variant.Filled" Color="Color.Default" FullWidth="true"
                               StartIcon="@(_coffee.FinishedAt is null ? Icons.Material.Filled.Check : Icons.Material.Filled.Refresh)"
                               OnClick="ToggleFinishedAsync">
                        @(_coffee.FinishedAt is null ? Loc.T("coffeedetail.btn_finish") : Loc.T("coffeedetail.btn_reopen"))
                    </MudButton>
                </MudItem>
                <MudItem xs="6">
                    <MudButton Variant="Variant.Filled" Color="Color.Error" FullWidth="true"
                               StartIcon="@Icons.Material.Filled.Delete"
                               OnClick="DeleteAsync">@Loc.T("common.delete")</MudButton>
                </MudItem>
            }
            else
            {
                <MudItem xs="12">
                    <MudButton Variant="Variant.Filled" Color="Color.Error" FullWidth="true"
                               StartIcon="@Icons.Material.Filled.Delete"
                               OnClick="DeleteAsync">@Loc.T("common.delete")</MudButton>
                </MudItem>
            }
        </MudGrid>
    </MudStack>
}

<style>
    .hero-photo {
        width: 100%;
        aspect-ratio: 1 / 1;
        object-fit: cover;
        border-radius: 18px;
    }
    .thumb-sm {
        width: 36px; height: 36px; border-radius: 10px;
    }
    .thumb-placeholder {
        background: var(--coffee-surface-soft); display: flex; align-items: center; justify-content: center; color: var(--coffee-accent-soft);
    }
    .degas-track {
        position: relative;
        height: 12px;
        border-radius: 6px;
        overflow: hidden;
        display: flex;
    }
    .degas-zone { height: 100%; }
    .z-fresh { width: 16.67%; background: #fee2e2; }   /* 0-7 days  (~7/42) */
    .z-filter { width: 0%; }
    .z-optimal { width: 33.33%; background: #d1fae5; } /* 7-21 days (~14/42) */
    .z-decline { width: 33.33%; background: #fef3c7; } /* 21-35     (~14/42) */
    .z-past { width: 16.67%; background: #fee2e2; }    /* 35-42     (~7/42) */
    .degas-marker {
        position: absolute;
        top: -3px;
        width: 4px;
        height: 18px;
        background: #3b2418;
        border-radius: 2px;
        transform: translateX(-50%);
        box-shadow: 0 1px 3px rgba(0,0,0,.2);
    }
    .degas-legend {
        display: flex;
        justify-content: space-between;
        font-size: 10px;
        color: #8a7560;
        margin-top: 4px;
        font-variant-numeric: tabular-nums;
    }
</style>

@code {
    [Parameter] public int Id { get; set; }

    private bool _loading = true;
    private Coffee? _coffee;
    private List<Brew> _brews = new();
    private Dictionary<int, Machine> _machinesById = new();
    private readonly HashSet<int> _selectedBrewIds = new();
    private List<ChartSeries<double>>? _chartSeries;
    private string[] _chartLabels = Array.Empty<string>();
    private readonly LineChartOptions _chartOptions = new()
    {
        YAxisTicks = 1,
        YAxisSuggestedMax = 5,
        ClampToZero = true,
        LineStrokeWidth = 2.5,
        ShowDataMarkers = true,
        ShowLegend = false,
        InterpolationOption = InterpolationOption.NaturalSpline,
        ChartPalette = new[] { "#3b2418" }
    };

    protected override void OnInitialized() => Loc.LanguageChanged += OnLangChanged;
    private void OnLangChanged() => InvokeAsync(StateHasChanged);
    public void Dispose() => Loc.LanguageChanged -= OnLangChanged;

    /// <summary>Convertit la zone de dégazage interne ("too-fresh"/"filter-only"/...) en clé de localisation.</summary>
    private static string ZoneToKey(string zone) => zone switch
    {
        "too-fresh" => "fresh",
        "filter-only" => "filter",
        "optimal" => "optimal",
        "declining" => "declining",
        _ => "past"
    };

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _selectedBrewIds.Clear();
        _coffee = await Db.Coffees.Get(Id);
        if (_coffee is not null)
        {
            var raw = await Db.Brews.Where(nameof(Brew.CoffeeId)).IsEqual(Id).ToList();
            _brews = raw.OrderByDescending(b => b.Date).ToList();
            var machines = await Db.Machines.ToCollection().ToList();
            _machinesById = machines.ToDictionary(m => m.Id, m => m);

            if (_brews.Count >= 3)
            {
                var ordered = _brews.OrderBy(b => b.Date).ToList();
                _chartSeries = new List<ChartSeries<double>>
                {
                    new()
                    {
                        Name = "Score",
                        Data = new ChartData<double>(ordered.Select(b => (double)b.Rating).ToList())
                    }
                };
                _chartLabels = ordered
                    .Select((_, i) => $"#{i + 1}")
                    .ToArray();
            }
            else
            {
                _chartSeries = null;
            }
        }
        _loading = false;
    }

    private void GoDuplicate(int brewId) => Nav.NavigateTo($"brews/new?fromBrewId={brewId}");

    private void ToggleSelected(int brewId)
    {
        if (_selectedBrewIds.Contains(brewId)) _selectedBrewIds.Remove(brewId);
        else if (_selectedBrewIds.Count < 2) _selectedBrewIds.Add(brewId);
        else
        {
            // Limite à 2 : on remplace le plus ancien sélectionné
            var oldest = _selectedBrewIds.First();
            _selectedBrewIds.Remove(oldest);
            _selectedBrewIds.Add(brewId);
        }
    }

    private async Task OpenCompareAsync()
    {
        if (_selectedBrewIds.Count != 2) return;
        var pair = _brews.Where(b => _selectedBrewIds.Contains(b.Id)).OrderBy(b => b.Date).ToList();
        var parameters = new DialogParameters
        {
            ["BrewA"] = pair[0],
            ["BrewB"] = pair[1],
            ["Machines"] = _machinesById
        };
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        await Dialogs.ShowAsync<BrewCompareDialog>("Comparaison de brews", parameters, options);
    }

    private decimal? CostPerGram =>
        _coffee?.Price is decimal price && _coffee?.WeightGrams is int weight && weight > 0
            ? Math.Round(price / weight, 4) : null;

    private decimal? AvgCostPerCup
    {
        get
        {
            if (CostPerGram is not decimal cpg) return null;
            var dosed = _brews.Where(b => b.DoseG is decimal d && d > 0).ToList();
            if (dosed.Count == 0) return null;
            var avgDose = dosed.Average(b => b.DoseG!.Value);
            return Math.Round(cpg * avgDose, 2);
        }
    }

    private string OriginLine()
    {
        var parts = new[] { _coffee?.Country, _coffee?.Region, _coffee?.Farm }
            .Where(s => !string.IsNullOrEmpty(s))
            .ToArray();
        return parts.Length == 0 ? Loc.T("common.none") : string.Join(" · ", parts);
    }

    private async Task OpenStockAdjustAsync()
    {
        if (_coffee is null) return;
        var sumBrews = _brews.Sum(b => b.DoseG ?? 0m);
        var parameters = new DialogParameters
        {
            ["Coffee"] = _coffee,
            ["SumBrewsG"] = sumBrews
        };
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true };
        var dialogRef = await Dialogs.ShowAsync<StockAdjustmentDialog>(Loc.T("stockdialog.title"), parameters, options);
        var result = await dialogRef.Result;
        if (result is not null && !result.Canceled)
        {
            // Le coffee a été modifié dans le dialog — rafraîchir la vue.
            _coffee = await Db.Coffees.Get(Id);
            StateHasChanged();
        }
    }

    private async Task ToggleFinishedAsync()
    {
        if (_coffee is null) return;
        _coffee.FinishedAt = _coffee.FinishedAt is null ? DateTime.UtcNow : null;
        _coffee.UpdatedAt = DateTime.UtcNow;
        await Db.Coffees.Put(_coffee);
        Sync.RequestPush();
        Snackbar.Add(_coffee.FinishedAt is null ? Loc.T("coffeedetail.snack_reopened") : Loc.T("coffeedetail.snack_finished"), Severity.Success);
    }

    private async Task DeleteAsync()
    {
        if (_coffee is null) return;
        var ok = await Dialogs.ShowMessageBoxAsync(new MessageBoxOptions
        {
            Title = Loc.T("coffeeform.btn_delete_confirm_title"),
            Message = Loc.T("coffeeform.btn_delete_confirm_msg", _coffee.Name),
            YesText = Loc.T("common.delete"),
            CancelText = Loc.T("common.cancel")
        });
        if (ok != true) return;

        var related = await Db.Brews.Where(nameof(Brew.CoffeeId)).IsEqual(Id).PrimaryKeys();
        foreach (var bId in related) await Db.Brews.Delete(bId);
        await Db.Coffees.Delete(Id);
        Sync.RequestPush();
        Snackbar.Add(Loc.T("coffeeform.snack_deleted"), Severity.Info);
        Nav.NavigateTo("coffees");
    }
}
